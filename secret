--// ====================== MOBILE BUTTONS ======================
-- (Mobil butonlar kısmı tamamen aynı bırakıldı)
repeat task.wait() until game:IsLoaded()
local MB_BW = 62
local MB_BH = 52
local MB_GAP = 12
local MB_VERTICAL_GAP = 16
local mbDefs = {
    {top="DROP", bot="BR", fk="drop"},
    {top="AUTO", bot="LEFT", fk="autoLeft"},
    {top="BAT", bot="AIMBOT", fk="batAimbot"},
    {top="AUTO", bot="RIGHT", fk="autoRight"},
    {top="TP", bot="DOWN", fk="tpDown"},
    {top="CARRY", bot="SPD", fk="carrySpeed"},
    {top="LAGGER", bot="CARRY", fk="laggerCarry"},
    {top="LAGGER", bot="MODE", fk="laggerMode"},
}

local mbGui = Instance.new("ScreenGui")
mbGui.Name = "ColtMobileButtons"
mbGui.ResetOnSpawn = false
mbGui.DisplayOrder = 999
mbGui.IgnoreGuiInset = true
mbGui.Parent = lp:WaitForChild("PlayerGui")

local function getPos(i)
    local col = (i-1) % 2
    local row = math.floor((i-1)/2)
    local startX = -(2 * MB_BW + MB_GAP + 20)
    local startY = -(4 * MB_BH + 3 * MB_VERTICAL_GAP) / 2 + 5
    return UDim2.new(1, startX + col*(MB_BW + MB_GAP), 0.5, startY + row*(MB_BH + MB_VERTICAL_GAP))
end

for i, bd in ipairs(mbDefs) do
    local wrap = Instance.new("Frame")
    wrap.Size = UDim2.new(0, MB_BW, 0, MB_BH)
    wrap.Position = getPos(i)
    wrap.BackgroundColor3 = Color3.fromRGB(8, 0, 0)
    wrap.BorderSizePixel = 0
    wrap.ZIndex = 30
    wrap.Parent = mbGui
    Instance.new("UICorner", wrap).CornerRadius = UDim.new(0, 12)
  
    local stroke = Instance.new("UIStroke", wrap)
    stroke.Thickness = 1.8
    stroke.Color = Color3.fromRGB(0, 100, 60)

    local top = Instance.new("TextLabel", wrap)
    top.Size = UDim2.new(1, -4, 0.52, 0)
    top.Position = UDim2.new(0, 2, 0, 0)
    top.BackgroundTransparency = 1
    top.Text = bd.top
    top.TextColor3 = Color3.fromRGB(255, 255, 255)
    top.Font = Enum.Font.GothamBlack
    top.TextScaled = true
    top.TextXAlignment = Enum.TextXAlignment.Center
    top.TextYAlignment = Enum.TextYAlignment.Bottom
    top.ZIndex = 31

    local bot = Instance.new("TextLabel", wrap)
    bot.Size = UDim2.new(1, -4, 0.48, 0)
    bot.Position = UDim2.new(0, 2, 0.52, 0)
    bot.BackgroundTransparency = 1
    bot.Text = bd.bot
    bot.TextColor3 = Color3.fromRGB(0, 255, 140)
    bot.Font = Enum.Font.GothamBold
    bot.TextScaled = true
    bot.TextXAlignment = Enum.TextXAlignment.Center
    bot.TextYAlignment = Enum.TextYAlignment.Top
    bot.ZIndex = 31

    local function toggle()
        -- Config[bd.fk] = not Config[bd.fk]  -- Config tablosu orijinalde tanımlı değilse burayı uyarla
        local active = not wrap:GetAttribute("Active") or false
        wrap:SetAttribute("Active", active)
        TweenService:Create(wrap, TweenInfo.new(0.22), {
            BackgroundColor3 = active and Color3.fromRGB(0, 170, 80) or Color3.fromRGB(8, 0, 0)
        }):Play()
        stroke.Color = active and Color3.fromRGB(0, 255, 140) or Color3.fromRGB(0, 100, 60)
    end

    wrap.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            toggle()
        end
    end)
end

