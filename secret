-- ==================== KRIMO FLASH TP & GIANT ====================
local function getFlashTool()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("Flash Teleport") or LocalPlayer.Backpack:FindFirstChild("Flash Teleport")
end

local function getGiantTool()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("Giant") or LocalPlayer.Backpack:FindFirstChild("Giant")
end

local function activateTool(tool)
    if tool and tool.Parent then
        tool.Parent = LocalPlayer.Character
        task.wait(0.1)
        tool:Activate()
        task.wait(0.2)
    end
end

-- ==================== UTILITY ====================
local function createCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
end

local function createStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or CONFIG.Accent.StrokeColor
    s.Thickness = thickness or 1.6
    s.Parent = parent
    return s
end

local function createGradient(parent)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 25, 10)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(80, 255, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 25, 10)),
    }
    g.Parent = parent
    return g
end

local function makeDraggable(frame)
    local dragging = false
    local dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            dragInput = input
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- ==================== TOGGLE ====================
local function createSimpleToggle(parent, yPos, text, default, callback)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, -20, 0, 32)
    toggleFrame.Position = UDim2.new(0, 10, 0, yPos)
    toggleFrame.BackgroundColor3 = Color3.fromRGB(20, 35, 25)
    toggleFrame.Parent = parent
    createCorner(toggleFrame, 6)
    createStroke(toggleFrame, CONFIG.Accent.StrokeColor, 1.2)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(180, 255, 200)
    label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame

    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0, 40, 1, 0)
    status.Position = UDim2.new(1, -12, 0, 0)
    status.AnchorPoint = Vector2.new(1, 0)
    status.BackgroundTransparency = 1
    status.Text = default and "ON" or "OFF"
    status.TextColor3 = default and Color3.fromRGB(120, 255, 140) or Color3.fromRGB(255, 90, 90)
    status.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    status.TextSize = 13
    status.TextXAlignment = Enum.TextXAlignment.Right
    status.Parent = toggleFrame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.BackgroundTransparency = 1
    button.Text = ""
    button.Parent = toggleFrame

    local enabled = default
    button.MouseButton1Click:Connect(function()
        enabled = not enabled
        status.Text = enabled and "ON" or "OFF"
        status.TextColor3 = enabled and Color3.fromRGB(120, 255, 140) or Color3.fromRGB(255, 90, 90)
        callback(enabled)
    end)
end

-- ==================== PROGRESS BAR ====================
local function createProgressBar(parent)
    local barFrame = Instance.new("Frame")
    barFrame.Name = "ProgressBar"
    barFrame.Size = UDim2.new(1, -20, 0, 10)
    barFrame.Position = UDim2.new(0, 10, 1, -22)
    barFrame.BackgroundColor3 = Color3.fromRGB(10, 22, 18)
    barFrame.BorderSizePixel = 0
    barFrame.Parent = parent
    createCorner(barFrame, 6)
    createStroke(barFrame, Color3.fromRGB(50, 80, 65), 1.8)
   
    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(80, 255, 140)
    fill.Parent = barFrame
    createCorner(fill, 6)

    local glow = Instance.new("UIGradient")
    glow.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 255, 200)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 255, 140)),
    }
    glow.Parent = fill

    ProgressBar = barFrame
    ProgressFill = fill
end

local function tweenProgress(targetSize, duration)
    if not ProgressFill then return end
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = tweenService:Create(ProgressFill, tweenInfo, {Size = targetSize})
    tween:Play()
    return tween
end

local function resetProgressBar()
    tweenProgress(UDim2.new(0, 0, 1, 0), RESET_ANIMATION_TIME)
end

local function animateProgressBar()
    if not ProgressFill then return end
    ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    tweenProgress(UDim2.new(1, 0, 1, 0), HOLD_ANIMATION_TIME)
end

-- ==================== AUTO FLASH (GÜÇLENDİRİLMİŞ) ====================
local function setupAutoFlash()
    ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
        if not autoFlashEnabled then return end
        if activeTriggers[prompt] then return end

        activeTriggers[prompt] = true
        local start = os.clock()
        local fired = false
        local conn

        animateProgressBar()

        conn = RunService.PreRender:Connect(function()
            if not prompt or not prompt.Parent then
                conn:Disconnect()
                activeTriggers[prompt] = nil
                resetProgressBar()
                return
            end

            local progress = (os.clock() - start) / HOLD_ANIMATION_TIME
            if not fired and progress >= triggerValue then
                fired = true
                conn:Disconnect()
                activeTriggers[prompt] = nil

                -- Krimo Flash mantığı
                local flash = getFlashTool()
                if flash then
                    activateTool(flash)
                else
                    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end

                task.delay(0.3, resetProgressBar)
            end
        end)

        prompt.PromptButtonHoldEnded:Connect(function()
            if not fired then
                conn:Disconnect()
                activeTriggers[prompt] = nil
                resetProgressBar()
            end
        end)
    end)
end

-- ==================== AUTO GIANT ====================
local function setupAutoGiant()
    spawn(function()
        while true do
            if autoGiantEnabled then
                local giant = getGiantTool()
                if giant then
                    activateTool(giant)
                end
            end
            task.wait(1.2)
        end
    end)
end

-- ==================== DİĞER SİSTEMLER ====================
local function setupAutoPotion()
    spawn(function()
        while true do
            if autoPotionEnabled then
                local char = LocalPlayer.Character
                if char then
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool and tool.Name:lower():find("potion") then
                        tool:Activate()
                    end
                end
            end
            task.wait(0.8)
        end
    end)
end

