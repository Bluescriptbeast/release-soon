    local autoBatSetActive = makeSeparateBtn("BtnAutoBat", "BAT\nAIMBOT",
            UDim2.new(1, COL1_X, BASE_Y, ROW_Y[2]), "CodexBtn_autobat.txt",
            function(setActive)
