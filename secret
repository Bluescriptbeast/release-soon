local function createProgressBar(parent)
    local barFrame = Instance.new("Frame")
    barFrame.Name = "ProgressBar"
    barFrame.Size = UDim2.new(1, -20, 0, 10)
    barFrame.Position = UDim2.new(0, 10, 1, -22)
    barFrame.BackgroundColor3 = Color3.fromRGB(10, 22, 18)
    barFrame.BorderSizePixel = 0
    barFrame.Parent = parent
    createCorner(barFrame, 6)
    createStroke(barFrame, Color3.fromRGB(50, 80, 65), 1.8)
    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(80, 255, 140)
    fill.Parent = barFrame
    createCorner(fill, 6)
    local glow = Instance.new("UIGradient")
    glow.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 255, 200)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 255, 140)),
    }
    glow.Parent = fill
    ProgressBar = barFrame
    ProgressFill = fill
end

local function tweenProgress(targetSize, duration)
    if not ProgressFill then return end
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local goal = {Size = targetSize}
    local tween = tweenService:Create(ProgressFill, tweenInfo, goal)
    tween:Play()
    return tween
end

local function resetProgressBar()
    tweenProgress(UDim2.new(0, 0, 1, 0), RESET_ANIMATION_TIME)
end

local function animateProgressBar()
    if not ProgressFill then return end
    ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    tweenProgress(UDim2.new(1, 0, 1, 0), HOLD_ANIMATION_TIME)
end

local function hasKeyword(text)
    if typeof(text) ~= "string" then return false end
    return string.find(string.lower(text), "you stole") ~= nil
end

local function kickPlayer()
    pcall(function()
        LocalPlayer:Kick("Discord@rznnq")
    end)
end

local function watchObject(obj)
    if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then
        return
    end
    if hasKeyword(obj.Text) then
        kickPlayer()
        return
    end
    local conn = obj:GetPropertyChangedSignal("Text"):Connect(function()
        if hasKeyword(obj.Text) then
            kickPlayer()
        end
    end)
    table.insert(connections, conn)
end

local function scan(parent)
    for _, obj in ipairs(parent:GetDescendants()) do
        watchObject(obj)
    end
end

local function watchGui(gui)
    scan(gui)
    local conn = gui.DescendantAdded:Connect(function(desc)
        watchObject(desc)
    end)
    table.insert(connections, conn)
end

local function setupAutoKick()
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        watchGui(gui)
    end
    table.insert(connections, PlayerGui.ChildAdded:Connect(function(gui)
        watchGui(gui)
    end))
end

local function cleanupAutoKick()
    for _, conn in ipairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    connections = {}
end

