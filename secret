        XScale = MainFrame.Position.X.Scale,
        XOffset = MainFrame.Position.X.Offset,
        YScale = MainFrame.Position.Y.Scale,
        YOffset = MainFrame.Position.Y.Offset
    } or nil
    
    local settingsPos = SettingsFrame and {
        XScale = SettingsFrame.Position.X.Scale,
        XOffset = SettingsFrame.Position.X.Offset,
        YScale = SettingsFrame.Position.Y.Scale,
        YOffset = SettingsFrame.Position.Y.Offset
    } or nil
    
    local apPos = AP_MainPanel and {
        XScale = AP_MainPanel.Position.X.Scale,
        XOffset = AP_MainPanel.Position.X.Offset,
        YScale = AP_MainPanel.Position.Y.Scale,
        YOffset = AP_MainPanel.Position.Y.Offset
    } or nil
    
    local data = {
        autoFlashEnabled = autoFlashEnabled,
        autoPotionEnabled = autoPotionEnabled,
        apSpammerEnabled = apSpammerEnabled,
        kickAfterStealEnabled = kickAfterStealEnabled,
        triggerValue = triggerValue,
        mainPosition = mainPos,
        settingsPosition = settingsPos,
        apPosition = apPos,
    }
    pcall(function()
        local json = HttpService:JSONEncode(data)
        writefile(CONFIG_FILE, json)
    end)
end

local function loadSettings()
    if isfile(CONFIG_FILE) then
        pcall(function()
            local content = readfile(CONFIG_FILE)
            local data = HttpService:JSONDecode(content)
           
            if data.autoFlashEnabled ~= nil then autoFlashEnabled = data.autoFlashEnabled end
            if data.autoPotionEnabled ~= nil then autoPotionEnabled = data.autoPotionEnabled end
            if data.apSpammerEnabled ~= nil then apSpammerEnabled = data.apSpammerEnabled end
            if data.kickAfterStealEnabled ~= nil then kickAfterStealEnabled = data.kickAfterStealEnabled end
            if data.triggerValue ~= nil then triggerValue = data.triggerValue end
           
            if data.mainPosition then
                CONFIG.MainFrame.Position = UDim2.new(
                    data.mainPosition.XScale,
                    data.mainPosition.XOffset,
                    data.mainPosition.YScale,
                    data.mainPosition.YOffset
                )
            end
            
            if data.settingsPosition then
                CONFIG.SettingsPosition = UDim2.new(
                    data.settingsPosition.XScale,
                    data.settingsPosition.XOffset,
                    data.settingsPosition.YScale,
                    data.settingsPosition.YOffset
                )
            end
            
            if data.apPosition then
                CONFIG.APPosition = UDim2.new(
                    data.apPosition.XScale,
                    data.apPosition.XOffset,
                    data.apPosition.YScale,
                    data.apPosition.YOffset
                )
            end
        end)
    end
end

