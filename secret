-- Toggle Butonları
local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function setState(active, cardStroke, statusLabel, pillBg, knob)
	if active then
		TweenService:Create(cardStroke, tweenInfo, {Color = Color3.fromRGB(0, 255, 0)}):Play()
		statusLabel.Text = "ENABLED"
		TweenService:Create(statusLabel, tweenInfo, {TextColor3 = Color3.fromRGB(0, 255, 0)}):Play()
		TweenService:Create(pillBg, tweenInfo, {BackgroundColor3 = Color3.fromRGB(0, 30, 0)}):Play()
		TweenService:Create(knob, tweenInfo, {BackgroundColor3 = Color3.fromRGB(0, 255, 0)}):Play()
		TweenService:Create(knob, tweenInfo, {Position = UDim2.new(0, 22, 0.5, -7)}):Play()
	else
		TweenService:Create(cardStroke, tweenInfo, {Color = Color3.fromRGB(0, 80, 0)}):Play()
		statusLabel.Text = "DISABLED"
		TweenService:Create(statusLabel, tweenInfo, {TextColor3 = Color3.fromRGB(0, 150, 0)}):Play()
		TweenService:Create(pillBg, tweenInfo, {BackgroundColor3 = Color3.fromRGB(0, 40, 0)}):Play()
		TweenService:Create(knob, tweenInfo, {BackgroundColor3 = Color3.fromRGB(80, 85, 95)}):Play()
		TweenService:Create(knob, tweenInfo, {Position = UDim2.new(0, 4, 0.5, -7)}):Play()
	end
end

