local function updateToggles()
    local mainGoal = laggerActive and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    local mainColor = laggerActive and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(40, 60, 55)
    TweenService:Create(switchKnob, TweenInfo.new(0.15), {Position = mainGoal}):Play()
    TweenService:Create(switchBg, TweenInfo.new(0.15), {BackgroundColor3 = mainColor}):Play()

    local lowGoal = lowEndActive and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    local lowColor = lowEndActive and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(40, 60, 55)
    TweenService:Create(lowEndKnob, TweenInfo.new(0.15), {Position = lowGoal}):Play()
    TweenService:Create(lowEndSwitchBg, TweenInfo.new(0.15), {BackgroundColor3 = lowColor}):Play()
end

local function toggleLagger()
    laggerActive = not laggerActive
    if laggerActive then startMainThread() else stopMainThread() end
    updateToggles()
end

local function toggleLowEnd()
    lowEndActive = not lowEndActive
    if lowEndActive then startLowEndThread() else stopLowEndThread() end
    updateToggles()
end

