--// ==================== ESP ====================
local ESP = { Enabled = false, Connections = {}, Boxes = {}, Tracers = {}, Distances = {} }
-- (ESP kodunu önceki tam versiyondan aldım, kısaltmadım)

local function createESP(plr)
    if plr == lp then return end
    local box = Drawing.new("Square") box.Thickness = 2 box.Color = Color3.fromRGB(0,210,255) box.Filled = false box.Transparency = 1
    local tracer = Drawing.new("Line") tracer.Thickness = 1.5 tracer.Color = Color3.fromRGB(0,180,255) tracer.Transparency = 0.8
    local distanceLabel = Drawing.new("Text") distanceLabel.Size = 14 distanceLabel.Color = Color3.fromRGB(255,255,255) distanceLabel.Center = true distanceLabel.Outline = true
    ESP.Boxes[plr] = box ESP.Tracers[plr] = tracer ESP.Distances[plr] = distanceLabel
end

local function updateESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == lp then continue end
        local char = plr.Character local root = char and char:FindFirstChild("HumanoidRootPart")
        local hrp = getHRP()
        if char and root and hrp and ESP.Enabled then
            local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
            if onScreen then
                local top = workspace.CurrentCamera:WorldToViewportPoint(root.Position + Vector3.new(0,3,0))
                local bottom = workspace.CurrentCamera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))
                local height = (top - bottom).Y local width = height * 0.6
                ESP.Boxes[plr].Size = Vector2.new(width, height)
                ESP.Boxes[plr].Position = Vector2.new(screenPos.X - width/2, screenPos.Y - height/2)
                ESP.Boxes[plr].Visible = true
                ESP.Tracers[plr].From = Vector2.new(workspace.CurrentCamera.ViewportSize.X/2, workspace.CurrentCamera.ViewportSize.Y)
                ESP.Tracers[plr].To = Vector2.new(screenPos.X, screenPos.Y)
                ESP.Tracers[plr].Visible = true
                local dist = (root.Position - hrp.Position).Magnitude
                ESP.Distances[plr].Text = string.format("%.1f m", dist)
                ESP.Distances[plr].Position = Vector2.new(screenPos.X, screenPos.Y - height/2 - 18)
                ESP.Distances[plr].Visible = true
            else
                if ESP.Boxes[plr] then ESP.Boxes[plr].Visible = false end
                if ESP.Tracers[plr] then ESP.Tracers[plr].Visible = false end
                if ESP.Distances[plr] then ESP.Distances[plr].Visible = false end
            end
        else
            if ESP.Boxes[plr] then ESP.Boxes[plr].Visible = false end
            if ESP.Tracers[plr] then ESP.Tracers[plr].Visible = false end
            if ESP.Distances[plr] then ESP.Distances[plr].Visible = false end
        end
    end
end

local function startESP()
    if ESP.Connections.update then return end
    for _, plr in ipairs(Players:GetPlayers()) do createESP(plr) end
    ESP.Connections.update = RunService.RenderStepped:Connect(updateESP)
end

local function stopESP()
    if ESP.Connections.update then ESP.Connections.update:Disconnect() end
    for _, v in pairs(ESP.Boxes) do v:Remove() end
    for _, v in pairs(ESP.Tracers) do v:Remove() end
    for _, v in pairs(ESP.Distances) do v:Remove() end
end

