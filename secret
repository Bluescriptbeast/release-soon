local function refreshList()
    for _, v in pairs(Scroll:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            createPlayerCard(player)
        end
    end
end

Players.PlayerAdded:Connect(refreshList)
Players.PlayerRemoving:Connect(refreshList)
refreshList()

-- Spam Closest Fonksiyonu
local CMDS = {"rocket","ragdoll","balloon","inverse","nightvision","jail","control","tiny","jumpscare","morph"}
local DUR = {rocket=119,ragdoll=29,balloon=29,inverse=59,nightvision=59,jail=59,control=59,tiny=59,jumpscare=59,morph=59}
local cooldowns = {}

local function spamClosest()
    if not core.remote then return end

    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local best, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and p.Character then
            local h = p.Character:FindFirstChild("HumanoidRootPart")
            if h then
                local d = (h.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    best = p
                end
            end
        end
    end

    if not best then return end

    local now = tick()
    for _, cmd in ipairs(CMDS) do
        if (cooldowns[cmd] or 0) <= now then
            pcall(function()
                core.remote:InvokeServer("f888ee6e-c86d-46e1-93d7-0639d6635d42", best, cmd)
            end)
            cooldowns[cmd] = now + (DUR[cmd] or 30)
        end
    end
end

-- Buton ve C Tuşu
SpamBtn.MouseButton1Click:Connect(spamClosest)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.C then
        spamClosest()
    end
end)

