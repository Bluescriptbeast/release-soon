local function RefreshPlayerList()
    for _, card in pairs(PlayerCards) do
        pcall(function() card:Destroy() end)
    end
    table.clear(PlayerCards)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local card = Instance.new("TextButton")
        card.Name = player.Name
        card.Size = UDim2.new(1, -8, 0, 28)
        card.BackgroundColor3 = Colors.Card
        card.Text = ""
        card.ZIndex = 2
        card.Parent = ScrollingFrame

        ApplyCorner(card, 6)
        local cardStroke = ApplyStroke(card, 1.5, Colors.Border)

        local avatar = Instance.new("ImageLabel")
        avatar.Size = UDim2.new(0, 20, 0, 20)
        avatar.Position = UDim2.new(0, 5, 0.5, -10)
        avatar.BackgroundTransparency = 1
        avatar.ZIndex = 3
        avatar.Parent = card

        local success, thumbnail = pcall(function()
            return Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        end)
        avatar.Image = success and thumbnail or ""

        ApplyCorner(avatar, 10)

        CreateLabel(card, {
            Position = UDim2.new(0, 30, 0, 3),
            Size = UDim2.new(1, -38, 0, 11),
            Font = Enum.Font.GothamBold,
            TextSize = 9,
            TextColor3 = Colors.White,
            TextXAlignment = Enum.TextXAlignment.Left,
            Text = player.DisplayName,
            ZIndex = 3
        })

        CreateLabel(card, {
            Position = UDim2.new(0, 30, 0, 15),
            Size = UDim2.new(1, -38, 0, 9),
            Font = Enum.Font.Gotham,
            TextSize = 8,
            TextColor3 = Colors.Grey,
            TextXAlignment = Enum.TextXAlignment.Left,
            Text = "@" .. player.Name,
            ZIndex = 3
        })

        card.MouseButton1Click:Connect(function()
            SelectedPlayer = (SelectedPlayer == player) and nil or player

            for _, c in pairs(PlayerCards) do
                local s = c:FindFirstChildOfClass("UIStroke")
                if s then s.Color = Colors.Border end
            end

            if SelectedPlayer == player then
                cardStroke.Color = Colors.SelectedBorder
            end
        end)

        PlayerCards[player.UserId] = card
    end
end

