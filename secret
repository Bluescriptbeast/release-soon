-- Sadece Progress Bar GUI
local gui = Instance.new("ScreenGui")
gui.Name = "MeowlGrabBar"
gui.ResetOnSpawn = false
gui.DisplayOrder = 999
gui.IgnoreGuiInset = true

if not pcall(function() gui.Parent = game:GetService("CoreGui") end) then
    gui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
end

local pbFrame = Instance.new("Frame", gui)
pbFrame.Name = "ProgressBar"
pbFrame.Size = UDim2.new(0, 300, 0, 50)
pbFrame.Position = UDim2.new(0.5, -150, 0.8, 0)
pbFrame.BackgroundColor3 = Color3.fromRGB(8, 20, 8)
pbFrame.BorderSizePixel = 0
pbFrame.Active = true

Instance.new("UICorner", pbFrame).CornerRadius = UDim.new(0, 14)

local stroke = Instance.new("UIStroke", pbFrame)
stroke.Color = Color3.fromRGB(0, 255, 140)
stroke.Thickness = 2.5

-- Draggable (Taşınabilir)
local dragging = false
local dragInput
local dragStart
local startPos

pbFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = pbFrame.Position
    end
end)

pbFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        local delta = input.Position - dragStart
        pbFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Progress Fill
local fill = Instance.new("Frame", pbFrame)
fill.Size = UDim2.new(0, 0, 1, 0)
fill.BackgroundColor3 = Color3.fromRGB(0, 255, 140)
fill.BorderSizePixel = 0
Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 14)

-- Progress Text
local progressText = Instance.new("TextLabel", pbFrame)
progressText.Size = UDim2.new(1, 0, 0.5, 0)
progressText.BackgroundTransparency = 1
progressText.Text = "0%"
progressText.TextColor3 = Color3.fromRGB(255, 255, 255)
progressText.Font = Enum.Font.GothamBold
progressText.TextSize = 16
progressText.TextStrokeTransparency = 0.5

-- Radius Text
local radiusText = Instance.new("TextLabel", pbFrame)
radiusText.Size = UDim2.new(1, 0, 0.5, 0)
radiusText.Position = UDim2.new(0, 0, 0.5, 0)
radiusText.BackgroundTransparency = 1
radiusText.Text = "Radius: 12"
radiusText.TextColor3 = Color3.fromRGB(160, 255, 160)
radiusText.Font = Enum.Font.Gotham
radiusText.TextSize = 13
radiusText.TextStrokeTransparency = 0.7

print("✅ Sadece Progress Bar GUI Yüklendi!")
