-- ====================== GELİŞMİŞ OBFUSCATOR ======================
local function simpleShiftObf(str)
    if not str or str == "" then
        return "print('Kod girilmedi!')"
    end

    local shift = 137
    local encoded = {}
    
    for i = 1, #str do
        local b = string.byte(str, i)
        local c = (b + shift) % 256
        table.insert(encoded, string.char(c))
        shift = (shift * 17 + b) % 256
    end

    local payload = table.concat(encoded)

    local template = [[
return (function()
    local env = getfenv and getfenv() or _ENV
    local sub, char, concat, byte = env.string.sub, env.string.char, env.table.concat, env.string.byte
    local load = env.loadstring or env.load
    local pcall = env.pcall
    
    local data = ]] .. string.format("%q", payload) .. [[
    local shift = 137
    local decoded = {}
    
    for i = 1, #data do
        local b = byte(data, i)
        local orig = (b - shift) % 256
        table.insert(decoded, char(orig))
        shift = (shift * 17 + orig) % 256
    end
    
    local success, func = pcall(load, concat(decoded))
    if success then
        return func()
    else
        return func
    end
end)()
]]

    return template
end

