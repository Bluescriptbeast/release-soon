local function ApplyStyledStroke(parent)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 2.8
    stroke.Color = Color3.fromRGB(80, 255, 120)
    stroke.Parent = parent

    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 25, 10)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(80, 255, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 25, 10))
    })
    gradient.Parent = stroke

    task.spawn(function()
        local angle = 0
        while stroke and stroke.Parent do
            angle = angle + 2.2
            gradient.Rotation = angle
            task.wait(0.018)
        end
    end)
end

