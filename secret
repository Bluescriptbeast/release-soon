local function getHRP()
    local char = LocalPlayer.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

-- ====================== ANTI BAT ======================
local function startantibat()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if antibatconn then antibatconn:Disconnect() end
    antibatconn = RunService.Heartbeat:Connect(function()
        if not root or not root.Parent then return end
        local vel = root.AssemblyLinearVelocity
        local origX, origZ = vel.X, vel.Z
        root.AssemblyLinearVelocity = Vector3.new(1000, vel.Y, 1000)
        RunService.RenderStepped:Wait()
        vel = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(origX, vel.Y, origZ)
    end)
end

local function stopantibat()
    if antibatconn then
        antibatconn:Disconnect()
        antibatconn = nil
    end
end

-- ====================== INFINITY JUMP (BYPASS VERSİYONU) ======================
local function startInfiniteJump()
    if infJumpConn1 then infJumpConn1:Disconnect() end
    if infJumpConn2 then infJumpConn2:Disconnect() end

    local lastJump = 0

    infJumpConn1 = UserInputService.JumpRequest:Connect(function()
        if not infJumpEnabled then return end
       
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if not hum or not root then return end

        local now = tick()
        if now - lastJump < 0.23 then return end -- Anti-spam
        lastJump = now

        hum.JumpPower = 47
        hum.Jump = true

        -- Çok hafif ve kısa boost (daha doğal his)
        task.delay(0.035, function()
            if root and root.Parent then
                local vel = root.AssemblyLinearVelocity
                root.AssemblyLinearVelocity = Vector3.new(vel.X, 44, vel.Z)
            end
        end)
    end)

    -- Düşüş clamp (daha yumuşak)
    infJumpConn2 = RunService.Heartbeat:Connect(function()
        if not infJumpEnabled then return end
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if root and root.AssemblyLinearVelocity.Y < -78 then
            root.AssemblyLinearVelocity = Vector3.new(
                root.AssemblyLinearVelocity.X,
                -78,
                root.AssemblyLinearVelocity.Z
            )
        end
    end)
end

local function stopInfiniteJump()
    if infJumpConn1 then infJumpConn1:Disconnect() end
    if infJumpConn2 then infJumpConn2:Disconnect() end
    infJumpConn1 = nil
    infJumpConn2 = nil

    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.JumpPower = 50 end
    end
end

local function toggleInfJump(state)
    infJumpEnabled = state
    if state then
        startInfiniteJump()
    else
        stopInfiniteJump()
    end
end

