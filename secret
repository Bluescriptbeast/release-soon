local function loadConfig()

   local has = false

   pcall(function() has = _isfile(CONFIG_FILE) end)

   if not has then return end

   local raw; pcall(function() raw = _readfile(CONFIG_FILE) end)

   if not raw then return end

   local cfg; local ok = pcall(function() cfg = HttpService:JSONDecode(raw) end)

   if not ok or not cfg then return end

   if cfg.normalSpeed then State.normalSpeed = cfg.normalSpeed end

   if cfg.carrySpeed then State.carrySpeed = cfg.carrySpeed end

   if cfg.laggerSpeed then State.laggerSpeed = cfg.laggerSpeed end

   if cfg.aimbotSpeed then State.aimbotSpeed = cfg.aimbotSpeed end

   if cfg.stealRadius then Steal.StealRadius = cfg.stealRadius end

   if cfg.stealDuration then Steal.StealDuration = cfg.stealDuration end

   if cfg.infJump ~= nil then State.infJumpEnabled = cfg.infJump end

   if cfg.antiRagdoll ~= nil then State.antiRagdollEnabled = cfg.antiRagdoll end

   if cfg.fpsBoost ~= nil then State.fpsBoostEnabled = cfg.fpsBoost end

   if cfg.medusaCounter ~= nil then State.medusaCounterEnabled = cfg.medusaCounter end

   if cfg.batCounter ~= nil then State.batCounterEnabled = cfg.batCounter end

   if cfg.autoSwing ~= nil then State.autoSwingEnabled = cfg.autoSwing end

   if cfg.autoSteal ~= nil then Steal.AutoStealEnabled = cfg.autoSteal; State.autoStealEnabled = cfg.autoSteal end

   if cfg.unwalkState ~= nil then State.unwalkEnabled = cfg.unwalkState end

   if cfg.laggerMode ~= nil then State.laggerEnabled = cfg.laggerMode end

   if cfg.batAimbot ~= nil then State.batAimbotToggled = cfg.batAimbot end

   if cfg.uiLocked ~= nil then State.uiLocked = cfg.uiLocked end

   if cfg.hideButtons ~= nil then State.hideButtonsEnabled = cfg.hideButtons end

   if cfg.darkMode ~= nil then State.darkModeEnabled = cfg.darkMode end

   if cfg.removeAccessories ~= nil then State.removeAccessoriesEnabled = cfg.removeAccessories end

   if cfg.fov then State.fov = cfg.fov end

   if cfg.uiScale then State.uiScale = cfg.uiScale end

   if cfg.carryMode ~= nil then State.speedToggled = cfg.carryMode end

   if cfg.dropBrainrot ~= nil then State.dropEnabled = cfg.dropBrainrot end

   if cfg.autoSaveEnabled ~= nil then State.autoSaveEnabled = cfg.autoSaveEnabled end

   local function tryKey(field, kt)

       if cfg[field] and Enum.KeyCode[cfg[field]] then Keys[kt] = Enum.KeyCode[cfg[field]] end

   end

   tryKey("speedKey","speed"); tryKey("autoLeftKey","autoLeft"); tryKey("autoRightKey","autoRight")

   tryKey("guiHideKey","guiHide"); tryKey("dropKey","drop"); tryKey("laggerKey","lagger")

   tryKey("tpDownKey","tpDown"); tryKey("aimbotKey","aimbot"); tryKey("unwalkKey","unwalk")

end

