       removeAccessories = State.removeAccessoriesEnabled,

       carryMode = State.speedToggled, dropBrainrot = State.dropEnabled,

       autoSaveEnabled = State.autoSaveEnabled,

   }

   local ok, enc = pcall(function() return HttpService:JSONEncode(cfg) end)

   if ok and enc then pcall(function() _writefile(CONFIG_FILE, enc) end) end

   if _onSaved then task.spawn(_onSaved) end

