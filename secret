-- Tüm Kartlar
local cardMap = {}
local function refreshCards()
    for _,v in pairs(cardMap) do v:Destroy() end
    table.clear(cardMap)

    for _,p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        local card = Instance.new("TextButton")
        card.Size = UDim2.new(1,-6,0,26)
        card.BackgroundColor3 = C.card
        card.Text = ""
        card.Parent = scroll
        corner(card,5)
        stroke(card,1,C.border)

        local ava = Instance.new("ImageLabel")
        ava.Size = UDim2.new(0,18,0,18)
        ava.Position = UDim2.new(0,4,0.5,-9)
        ava.BackgroundTransparency = 1
        ava.Image = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        ava.Parent = card
        corner(ava,9)

        lbl(card,{Position=UDim2.new(0,26,0,3),Size=UDim2.new(1,-30,0,20),Font=Enum.Font.GothamBold,TextSize=7.5,TextColor3=C.white,Text=p.DisplayName,TextXAlignment=Enum.TextXAlignment.Left})

        card.MouseButton1Click:Connect(function()
            createSingleCard(p)  -- Minimize modunda bu kişi gözüksün
        end)
        cardMap[p] = card
    end
end

Players.PlayerAdded:Connect(refreshCards)
