local tweeninfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function setstate(active, status, pillbg, knob, stroke)
    if active then
        TweenService:Create(stroke, tweeninfo, {Color = Color3.fromRGB(0, 255, 80)}):Play()
        TweenService:Create(status, tweeninfo, {TextColor3 = Color3.fromRGB(0, 255, 80)}):Play()
        status.Text = "ENABLED"
        TweenService:Create(pillbg, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 50, 20)}):Play()
        TweenService:Create(knob, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 255, 100)}):Play()
        TweenService:Create(knob, tweeninfo, {Position = UDim2.new(0, 24, 0.5, -7)}):Play()
    else
        TweenService:Create(stroke, tweeninfo, {Color = Color3.fromRGB(0, 80, 0)}):Play()
        TweenService:Create(status, tweeninfo, {TextColor3 = Color3.fromRGB(0, 150, 0)}):Play()
        status.Text = "DISABLED"
        TweenService:Create(pillbg, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 40, 0)}):Play()
        TweenService:Create(knob, tweeninfo, {BackgroundColor3 = Color3.fromRGB(80, 85, 95)}):Play()
        TweenService:Create(knob, tweeninfo, {Position = UDim2.new(0, 4, 0.5, -7)}):Play()
    end
end

