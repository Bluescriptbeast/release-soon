      frame.Position = UDim2.new(0, relX + 2, 0, relY + 2)
      halo1.BackgroundTransparency = 0.45
      halo2.BackgroundTransparency = 0.28
   end)
   btn.MouseButton1Up:Connect(function()
      frame.Size = UDim2.new(0, QS, 0, QS)
      frame.Position = UDim2.new(0, relX, 0, relY)
      if not active then
         halo1.BackgroundTransparency = 0.78
         halo2.BackgroundTransparency = 0.62
      end
   end)
   btn.MouseButton1Click:Connect(function()
      if isToggle then active = not active; setActive(active) end
      onAction(active)
   end)

   return btn, setActive
end

