-- Function to create Toggles with Logic
local function CreateToggle(name, configKey, hasInput, defaultVal)
    local Row = Instance.new("Frame")
    local Label = Instance.new("TextLabel")
    local ToggleBtn = Instance.new("TextButton")
    local Circle = Instance.new("Frame")
    
    Row.Name = name
    Row.Parent = ScrollingFrame
    Row.BackgroundTransparency = 1
    Row.Size = UDim2.new(1, 0, 0, 45)

    Label.Parent = Row
    Label.BackgroundTransparency = 1
    Label.Size = UDim2.new(0.5, 0, 1, 0)
    Label.Font = Enum.Font.GothamBold
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.TextSize = 16
    Label.TextXAlignment = Enum.TextXAlignment.Left

    ToggleBtn.Parent = Row
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    ToggleBtn.Position = UDim2.new(0.55, 0, 0.2, 0)
    ToggleBtn.Size = UDim2.new(0, 50, 0, 26)
    ToggleBtn.Text = ""
    local btnCorner = Instance.new("UICorner", ToggleBtn)
    btnCorner.CornerRadius = UDim.new(1, 0)

    Circle.Parent = ToggleBtn
    Circle.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Circle.Position = UDim2.new(0, 3, 0.5, -10)
    Circle.Size = UDim2.new(0, 20, 0, 20)
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

    -- Toggle Functionality
    ToggleBtn.MouseButton1Click:Connect(function()
        Toggles[configKey] = not Toggles[configKey]
        Circle:TweenPosition(
            Toggles[configKey] and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10),
            "Out", "Back", 0.3, true
        )
    end)

    if hasInput then
        local Input = Instance.new("TextBox")
        Input.Parent = Row
        Input.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        Input.Position = UDim2.new(0.78, 0, 0.2, 0)
        Input.Size = UDim2.new(0, 60, 0, 26)
        Input.Font = Enum.Font.GothamBold
        Input.Text = tostring(defaultVal)
        Input.TextColor3 = Color3.fromRGB(255, 255, 255)
        Input.TextSize = 14
        Instance.new("UICorner", Input).CornerRadius = UDim.new(0, 6)
        
        Input.FocusLost:Connect(function()
            Values[configKey == "FlashTP" and "TPDistance" or "SpeedAmount"] = tonumber(Input.Text) or defaultVal
        end)
    end
end

-- Init Toggles
CreateToggle("Flash TP", "FlashTP", true, 90.50)
