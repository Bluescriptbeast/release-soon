local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local antibatactive = false
local antibatconn = nil
local infJumpEnabled = false
local jumpConnection = nil
local fallConnection = nil

local INF_JUMP_FORCE = 54
local CLAMP_FALL = 80

local function getHRP()
    local char = LocalPlayer.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

-- ====================== ANTI BAT (Daha Az Detect Edilebilir) ======================
local function startantibat()
    if antibatconn then antibatconn:Disconnect() end
    
    local lastVel = Vector3.new(0, 0, 0)
    
    antibatconn = RunService.Heartbeat:Connect(function()
        local hrp = getHRP()
        if not hrp or not hrp.Parent then return end
        
        local vel = hrp.AssemblyLinearVelocity
        lastVel = Vector3.new(vel.X, vel.Y, vel.Z)
        
        -- Daha yumuşak ve rastgele varyasyonlu anti-bat
        local x = 850 + math.random(-80, 80)
        local z = 850 + math.random(-80, 80)
        
        hrp.AssemblyLinearVelocity = Vector3.new(x, vel.Y, z)
        
        -- RenderStepped yerine daha stabil yöntem
        task.wait() 
        if hrp and hrp.Parent then
            hrp.AssemblyLinearVelocity = Vector3.new(lastVel.X, hrp.AssemblyLinearVelocity.Y, lastVel.Z)
        end
    end)
end

local function stopantibat()
    if antibatconn then
        antibatconn:Disconnect()
        antibatconn = nil
    end
end

-- ====================== INFINITY JUMP ======================
local function applyInfJump()
    if jumpConnection then jumpConnection:Disconnect() end
    if fallConnection then fallConnection:Disconnect() end

    jumpConnection = UserInputService.JumpRequest:Connect(function()
        if not infJumpEnabled then return end
        local hrp = getHRP()
        if not hrp then return end
        
        local vel = hrp.AssemblyLinearVelocity
        hrp.AssemblyLinearVelocity = Vector3.new(vel.X, INF_JUMP_FORCE, vel.Z)
    end)

    fallConnection = RunService.Heartbeat:Connect(function()
        if not infJumpEnabled then return end
        local hrp = getHRP()
        if not hrp then return end
        
        local vel = hrp.AssemblyLinearVelocity
        if vel.Y < -CLAMP_FALL then
            hrp.AssemblyLinearVelocity = Vector3.new(vel.X, -CLAMP_FALL, vel.Z)
        end
    end)
end

local function toggleInfJump(state)
    infJumpEnabled = state
    if state then
        applyInfJump()
    else
        if jumpConnection then jumpConnection:Disconnect() end
        if fallConnection then fallConnection:Disconnect() end
    end
end

-- Character respawn
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.8) -- Biraz daha güvenli bekleme
    if antibatactive then
        startantibat()
    end
    if infJumpEnabled then
        applyInfJump()
    end
end)

