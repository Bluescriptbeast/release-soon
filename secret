        Ts:Create(card1stroke, tweeninfo, {Color = Color3.fromRGB(0, 255, 0)}):Play()
        status1.Text = "ENABLED"
        Ts:Create(status1, tweeninfo, {TextColor3 = Color3.fromRGB(0, 255, 0)}):Play()
        Ts:Create(pillbg1, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 30, 0)}):Play()
        Ts:Create(knob1, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 255, 0)}):Play()
        Ts:Create(knob1, tweeninfo, {Position = UDim2.new(0, 22, 0.5, -7)}):Play()
    else
        Ts:Create(card1stroke, tweeninfo, {Color = Color3.fromRGB(0, 80, 0)}):Play()
        status1.Text = "DISABLED"
        Ts:Create(status1, tweeninfo, {TextColor3 = Color3.fromRGB(0, 150, 0)}):Play()
        Ts:Create(pillbg1, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 40, 0)}):Play()
