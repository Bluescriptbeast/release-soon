-- Cooldown Updater
RunService.RenderStepped:Connect(function()
	local now = tick()
	for _, cmd in ipairs(CMDS) do
		local l = cdLabels[cmd]
		if l and l.Parent then
			local cd = cooldowns[cmd] or 0
			if now >= cd then
				l.Text = "READY"
				l.TextColor3 = C.green
			else
				l.Text = math.ceil(cd - now) .. "s"
				l.TextColor3 = C.red
			end
		end
	end
end)

