-- ====================== GELİŞTİRİLMİŞ OBFUSCATOR ======================
local function obfuscate(str)
    if not str or str == "" then
        return "return print('Kod girilmedi!')"
    end

    -- Daha güçlü encoding
    local seed = 162
    local encoded = {}
    
    for i = 1, #str do
        local byte = string.byte(str, i)
        -- Karışık shift
        local shifted = (byte + seed) % 256
        table.insert(encoded, string.char(shifted))
        
        -- Seed'i daha karmaşık güncelle
        seed = (seed * 37 + byte * 13 + i * 7) % 256
    end

    local payload = table.concat(encoded)

    -- Daha güçlü template
    local template = [[
return (function()
    local env = getfenv and getfenv() or _ENV
    local str = ]] .. string.format("%q", payload) .. [[
    
    local seed = 162
    local decoded = {}
    
    for i = 1, #str do
        local b = string.byte(str, i)
        local original = (b - seed) % 256
        decoded[#decoded + 1] = string.char(original)
        seed = (seed * 37 + b * 13 + i * 7) % 256
    end
    
    local code = table.concat(decoded)
    
    -- Anti-debug & hook koruması
    local oldprint = print
    print = function(...) end
    
    local success, result = pcall(loadstring, code)
    print = oldprint
    
    if success then
        return result()
    else
        return result
    end
end)()
]]

    return template
end

