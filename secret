-- FEATHER PARTICLE SYSTEM (gentle floating feathers inside buttons)
local function spawnFeatherParticles(parent, zBase)
   local particles = {}
   local feathers = {}

   local function makeFeather()
      local f = Instance.new("ImageLabel", parent)
      f.Size = UDim2.new(0, math.random(5, 10), 0, math.random(3, 7))
      f.Position = UDim2.new(0, math.random(3, QS - 6), 0, math.random(-5, QS + 10))
      f.BackgroundTransparency = 1
      f.Image = "rbxasset://textures/ui/TextChat/General/EmojiImages/Crow.png" -- feather-like fallback
      f.ImageColor3 = Color3.fromRGB(210, 180, 140)
      f.ImageTransparency = 0.4 + math.random() * 0.3
      f.BorderSizePixel = 0
      f.ZIndex = zBase
      f.Rotation = math.random(-20, 20)
      return f
   end

   for _ = 1, 12 do
      table.insert(feathers, makeFeather())
   end

   local conn = RunService.Heartbeat:Connect(function(dt)
      if not parent.Parent then return end
      for _, f in ipairs(feathers) do
         if f and f.Parent then
            local ny = f.Position.Y.Offset + math.random(1, 3) * 0.8
            local nx = f.Position.X.Offset + (math.random() - 0.5) * 1.2
            if ny > QS + 8 then
               ny = -math.random(0, 10)
               nx = math.random(3, QS - 6)
               f.ImageTransparency = 0.4 + math.random() * 0.3
            end
            f.Position = UDim2.new(0, nx, 0, ny)
            f.Rotation = f.Rotation + (math.random() - 0.5) * 5
         end
      end
   end)

   table.insert(particles, conn)
   return particles
end

local function makeOwlMobBtn(label, col, row, isToggle, onAction)
