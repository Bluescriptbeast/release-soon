local function SaveConfig()
    local data = { Keybind = keybind.Name, LowEndKeybind = lowEndKeybind.Name }
    pcall(function() writefile(ConfigFile, HttpService:JSONEncode(data)) end)
end

local function LoadConfig()
    if isfile and isfile(ConfigFile) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(ConfigFile))
        end)
        if success and data then
            if data.Keybind then keybind = Enum.KeyCode[data.Keybind] or Enum.KeyCode.V end
            if data.LowEndKeybind then lowEndKeybind = Enum.KeyCode[data.LowEndKeybind] or Enum.KeyCode.L end
        end
    end
end

