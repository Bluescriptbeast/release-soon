local MB_GAP = 12
local MB_VERTICAL_GAP = 16

local mbDefs = {
    {top="DROP", bot="BR", fk="drop", fn=function() print("🌀 DROP BRAINROT") end},
    {top="AUTO", bot="LEFT", fk="autoLeft", isT=true},
