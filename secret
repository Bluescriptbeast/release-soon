local FovFill = Instance.new("Frame")
FovFill.Size = UDim2.new((currentFov-70)/50,0,1,0)
FovFill.BackgroundColor3 = CONFIG.Slider.FillColor
FovFill.Parent = FovBar
createCorner(FovFill,4)

local FovKnob = Instance.new("Frame")
FovKnob.Size = UDim2.new(0,10,0,10)
FovKnob.Position = UDim2.new((currentFov-70)/50,-5,0.5,-5)
FovKnob.BackgroundColor3 = CONFIG.Slider.KnobColor
FovKnob.Parent = FovBar
createCorner(FovKnob,10)

local draggingFov = false

local function updateFov(v)
    v = math.clamp(v,0,1)
    currentFov = math.floor(70 + (v * 50))
    FovFill.Size = UDim2.new(v,0,1,0)
    FovKnob.Position = UDim2.new(v,-5,0.5,-5)
    FovValue.Text = tostring(currentFov)
    if fovEnabled then Camera.FieldOfView = currentFov end
    saveConfig()
end

FovBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingFov = true
        updateFov((input.Position.X - FovBar.AbsolutePosition.X) / FovBar.AbsoluteSize.X)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingFov and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateFov((input.Position.X - FovBar.AbsolutePosition.X) / FovBar.AbsoluteSize.X)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingFov = false
    end
end)

