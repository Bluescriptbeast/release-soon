    {top="CARRY", bot="SPD", fk="carrySpeed", isT=true},
    {top="LAGGER", bot="CARRY", fk="lagger", isT=true},
    {top="LAGGER", bot="MODE", fk="lagger", isT=true},
}

local mbGui = Instance.new("ScreenGui")
mbGui.Name = "KawatanMobileButtons"
mbGui.ResetOnSpawn = false
mbGui.DisplayOrder = 30
mbGui.IgnoreGuiInset = true
mbGui.Parent = lp:WaitForChild("PlayerGui")

local function getDefaultPos(i)
    local col = (i-1) % 2
    local row = math.floor((i-1)/2)
    local startX = -(2 * MB_BW + MB_GAP + 20)
    local startY = -(4 * MB_BH + 3 * MB_VERTICAL_GAP) / 2 + 5
    return UDim2.new(1, startX + col*(MB_BW + MB_GAP), 0.5, startY + row*(MB_BH + MB_VERTICAL_GAP))
end

local function rebuildButtons()
    for _, v in ipairs(mbGui:GetChildren()) do v:Destroy() end
    for i, bd in ipairs(mbDefs) do
        local wrap = Instance.new("Frame", mbGui)
        wrap.Size = UDim2.new(0, MB_BW, 0, MB_BH)
        wrap.Position = getDefaultPos(i)
        wrap.BackgroundColor3 = Color3.fromRGB(8, 0, 0)
        wrap.BorderSizePixel = 0
        wrap.Active = true
        wrap.ZIndex = 30
        Instance.new("UICorner", wrap).CornerRadius = UDim.new(0, 12)

        local stroke = Instance.new("UIStroke", wrap)
        stroke.Thickness = 1.8
        stroke.Color = Color3.fromRGB(130, 15, 15)

        local top = Instance.new("TextLabel", wrap)
        top.Size = UDim2.new(1,0,0.5,0)
        top.BackgroundTransparency = 1
        top.Text = bd.top
        top.TextColor3 = Color3.fromRGB(255,255,255)
        top.Font = Enum.Font.GothamBlack
        top.TextSize = 11.5

        local bot = Instance.new("TextLabel", wrap)
        bot.Size = UDim2.new(1,0,0.5,0)
        bot.Position = UDim2.new(0,0,0.5,0)
        bot.BackgroundTransparency = 1
        bot.Text = bd.bot or ""
        bot.TextColor3 = Color3.fromRGB(255, 110, 110)
        bot.Font = Enum.Font.GothamBold
        bot.TextSize = 9.5

        local isActive = Config[bd.fk] or false
        local function setActive(v)
            Config[bd.fk] = v
            TweenService:Create(wrap, TweenInfo.new(0.22), {
                BackgroundColor3 = v and Color3.fromRGB(170,20,20) or Color3.fromRGB(8,0,0)
            }):Play()
            stroke.Color = v and Color3.fromRGB(240,55,55) or Color3.fromRGB(130,15,15)
        end
        if isActive then setActive(true) end

        wrap.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                if bd.fn then
                    bd.fn()
                else
                    local newState = not Config[bd.fk]
                    setActive(newState)
                    saveConfig()
                end
            end
        end)
    end
end

