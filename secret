   halo1.BackgroundTransparency = 0.78
   halo1.BorderSizePixel = 0; halo1.ZIndex = 99
   addCorner(halo1, QR + 6)

   -- Inner glow halo (lighter warm brown)
   local halo2 = Instance.new("Frame", mbGroup)
