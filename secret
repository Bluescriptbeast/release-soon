        if not RealAPRemote or not SelectedPlayer then return end
        local currentTime = tick()
        for _, command in ipairs(Commands) do
            if (Cooldowns[command] or 0) <= currentTime then
                pcall(function()
                    RealAPRemote:InvokeServer("f888ee6e-c86d-46e1-93d7-0639d6635d42", SelectedPlayer, command)
                end)
                Cooldowns[command] = currentTime + Durations[command]
            end
        end
    end

    SpamButton.MouseButton1Click:Connect(SpamSelectedPlayer)
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.C then
            SpamSelectedPlayer()
        end
    end)
end

