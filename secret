-- ====================== ANTI BAT ======================
local antibatactive = false
local antibatconn = nil

local function startantibat()
	local char = Lp.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	if antibatconn then antibatconn:Disconnect() end
	antibatconn = Rs.Heartbeat:Connect(function()
		if not root or not root.Parent then return end
		local orig = root.Velocity
		root.Velocity = Vector3.new(1000, root.Velocity.Y, 1000)
		Rs.RenderStepped:Wait()
		root.Velocity = orig
	end)
end

local function stopantibat()
	if antibatconn then antibatconn:Disconnect() antibatconn = nil end
end

Lp.CharacterAdded:Connect(function()
	if antibatactive then 
		stopantibat() 
		task.wait(0.2) 
		startantibat() 
	end
end)

-- ====================== INFINITE JUMP ======================
local infJumpActive = false
local infJumpConn = nil
local jumpRequestConn = nil

local function toggleInfJump()
	infJumpActive = not infJumpActive
	
	if infJumpActive then
		-- AÇ
		InfJumpStatus.Text = "ENABLED"
		InfJumpStroke.Color = Color3.fromRGB(0, 255, 0)
		Ts:Create(InfJumpKnob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 22, 0.5, -7)}):Play()
		Ts:Create(InfJumpKnob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(0, 255, 0)}):Play()

		-- Jump Request
		if not jumpRequestConn then
			jumpRequestConn = Uis.JumpRequest:Connect(function()
				if not infJumpActive then return end
				local char = Lp.Character
				local hrp = char and char:FindFirstChild("HumanoidRootPart")
				if hrp then
					hrp.Velocity = Vector3.new(hrp.Velocity.X, 55, hrp.Velocity.Z)
				end
			end)
		end

		-- Düşüş kontrolü
		if not infJumpConn then
			infJumpConn = Rs.Heartbeat:Connect(function()
				if not infJumpActive then return end
				local char = Lp.Character
				local hrp = char and char:FindFirstChild("HumanoidRootPart")
				if hrp and hrp.Velocity.Y < -80 then
					hrp.Velocity = Vector3.new(hrp.Velocity.X, -80, hrp.Velocity.Z)
				end
			end)
		end
	else
		-- KAPAT
		InfJumpStatus.Text = "DISABLED"
		InfJumpStroke.Color = Color3.fromRGB(0, 80, 0)
		Ts:Create(InfJumpKnob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 4, 0.5, -7)}):Play()
		Ts:Create(InfJumpKnob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(80, 85, 95)}):Play()

		if jumpRequestConn then jumpRequestConn:Disconnect() jumpRequestConn = nil end
		if infJumpConn then infJumpConn:Disconnect() infJumpConn = nil end
	end
end

