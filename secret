local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ProximityPromptService = game:GetService("ProximityPromptService")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer

local CONFIG = {
    Gui = {
        ScreenGuiName = "Meowl Hub",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    },
    MainFrame = {
        Name = "Main",
        Size = UDim2.new(0, 240, 0, 180),
        Position = UDim2.new(0.5, -120, 0.5, -90),
        BackgroundColor3 = Color3.fromRGB(8, 20, 12),
        BackgroundTransparency = 0.08,
        BorderSizePixel = 0,
    },
    Accent = {
        StrokeColor = Color3.fromRGB(80, 255, 120),
        GradientRotationSpeed = 1.2,
    },
}

-- Variables
local ScreenGui, MainFrame, SettingsFrame
local stealSpeedValue = 0.85
local triggerValue = 0.92
local autoFlashEnabled = false
local stealSpeedEnabled = false
local activeTriggers = {}

local dragging = false

-- ==================== UTILITY ====================
local function createCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
end

local function createStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or CONFIG.Accent.StrokeColor
    s.Thickness = thickness or 1.8
    s.Parent = parent
    return s
end

local function createGradient(parent)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 25, 10)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(80, 255, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 25, 10)),
    }
    g.Parent = parent
    return g
end

-- ==================== GUI CREATION ====================
local function createMainGUI()
    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = CONFIG.Gui.ScreenGuiName
    ScreenGui.ResetOnSpawn = CONFIG.Gui.ResetOnSpawn
    ScreenGui.ZIndexBehavior = CONFIG.Gui.ZIndexBehavior
    ScreenGui.Parent = CoreGui

    MainFrame = Instance.new("Frame")
    MainFrame.Name = CONFIG.MainFrame.Name
    MainFrame.Size = CONFIG.MainFrame.Size
    MainFrame.Position = CONFIG.MainFrame.Position
    MainFrame.BackgroundColor3 = CONFIG.MainFrame.BackgroundColor3
    MainFrame.BackgroundTransparency = CONFIG.MainFrame.BackgroundTransparency
    MainFrame.BorderSizePixel = 0
    MainFrame.Active = true
    MainFrame.Parent = ScreenGui
    createCorner(MainFrame, 10)
    createStroke(MainFrame)
    createGradient(MainFrame:FindFirstChildWhichIsA("UIStroke"))

    -- Title Bar
    local TitleBar = Instance.new("Frame")
    TitleBar.Size = UDim2.new(1, 0, 0, 32)
    TitleBar.BackgroundTransparency = 1
    TitleBar.Parent = MainFrame

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -70, 1, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = "Meowl Hub - Steal"
    TitleLabel.TextColor3 = Color3.fromRGB(120, 255, 160)
    TitleLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    TitleLabel.TextSize = 14
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = TitleBar

    -- Settings Button
    local SettingsBtn = Instance.new("TextButton")
    SettingsBtn.Size = UDim2.new(0, 28, 0, 28)
    SettingsBtn.Position = UDim2.new(1, -34, 0, 2)
    SettingsBtn.BackgroundTransparency = 1
    SettingsBtn.Text = "⚙"
    SettingsBtn.TextColor3 = Color3.fromRGB(180, 255, 200)
    SettingsBtn.TextSize = 18
    SettingsBtn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    SettingsBtn.Parent = TitleBar

    -- ==================== TOGGLES ====================
    local function createToggle(yPos, text, default, callback)
        local toggleFrame = Instance.new("Frame")
        toggleFrame.Size = UDim2.new(1, -20, 0, 36)
        toggleFrame.Position = UDim2.new(0, 10, 0, yPos)
        toggleFrame.BackgroundTransparency = 1
        toggleFrame.Parent = MainFrame

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.7, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = Color3.fromRGB(180, 255, 200)
        label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium)
        label.TextSize = 13
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = toggleFrame

        local switch = Instance.new("Frame")
        switch.Size = UDim2.new(0, 42, 0, 22)
        switch.Position = UDim2.new(1, -50, 0.5, -11)
        switch.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        switch.Parent = toggleFrame
        createCorner(switch, 11)

        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 18, 0, 18)
        knob.Position = UDim2.new(0, 2, 0.5, -9)
        knob.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        knob.Parent = switch
        createCorner(knob, 9)

        local enabled = default

        local function updateVisual()
            if enabled then
                TweenService:Create(switch, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80, 255, 120)}):Play()
                TweenService:Create(knob, TweenInfo.new(0.2), {Position = UDim2.new(1, -20, 0.5, -9)}):Play()
            else
                TweenService:Create(switch, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
                TweenService:Create(knob, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, -9)}):Play()
            end
        end

        switch.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                enabled = not enabled
                updateVisual()
                callback(enabled)
            end
        end)

        updateVisual()
        return toggleFrame
    end

    createToggle(45, "Auto Flash", false, function(v) autoFlashEnabled = v end)
    createToggle(85, "Steal Speed", false, function(v) stealSpeedEnabled = v end)

    -- Align Button
    local AlignBtn = Instance.new("TextButton")
    AlignBtn.Size = UDim2.new(1, -20, 0, 36)
    AlignBtn.Position = UDim2.new(0, 10, 0, 125)
    AlignBtn.BackgroundColor3 = Color3.fromRGB(25, 35, 25)
    AlignBtn.Text = "Align Camera"
    AlignBtn.TextColor3 = Color3.fromRGB(180, 255, 200)
    AlignBtn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    AlignBtn.TextSize = 13
    AlignBtn.Parent = MainFrame
    createCorner(AlignBtn, 8)

    AlignBtn.MouseButton1Click:Connect(function()
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            local cam = workspace.CurrentCamera
            local cf = root.CFrame
            cam.CFrame = CFrame.lookAt(cam.CFrame.Position, cf.Position + cf.LookVector * 10)
        end
    end)

    return SettingsBtn
end

local function createSettingsGUI()
    SettingsFrame = Instance.new("Frame")
    SettingsFrame.Name = "Settings"
    SettingsFrame.Size = UDim2.new(0, 240, 0, 200)
    SettingsFrame.Position = MainFrame.Position
    SettingsFrame.BackgroundColor3 = CONFIG.MainFrame.BackgroundColor3
    SettingsFrame.BackgroundTransparency = CONFIG.MainFrame.BackgroundTransparency
    SettingsFrame.BorderSizePixel = 0
    SettingsFrame.Visible = false
    SettingsFrame.Parent = ScreenGui
    createCorner(SettingsFrame, 10)
    createStroke(SettingsFrame)
    createGradient(SettingsFrame:FindFirstChildWhichIsA("UIStroke"))

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 32)
    Title.BackgroundTransparency = 1
    Title.Text = "Settings"
    Title.TextColor3 = Color3.fromRGB(120, 255, 160)
    Title.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    Title.TextSize = 14
    Title.Parent = SettingsFrame

    local function createSlider(yPos, labelText, default, min, max, onChange)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(1, -20, 0, 50)
        container.Position = UDim2.new(0, 10, 0, yPos)
        container.BackgroundTransparency = 1
        container.Parent = SettingsFrame

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0, 18)
        label.BackgroundTransparency = 1
        label.Text = labelText
        label.TextColor3 = Color3.fromRGB(180, 255, 200)
        label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
        label.TextSize = 12
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = container

        local valueLabel = Instance.new("TextLabel")
        valueLabel.Size = UDim2.new(0, 40, 0, 18)
        valueLabel.Position = UDim2.new(1, -40, 0, 0)
        valueLabel.BackgroundTransparency = 1
        valueLabel.Text = math.floor(default * 100) .. "%"
        valueLabel.TextColor3 = Color3.fromRGB(180, 255, 200)
        valueLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
        valueLabel.TextSize = 12
        valueLabel.Parent = container

        local bar = Instance.new("Frame")
        bar.Size = UDim2.new(1, 0, 0, 6)
        bar.Position = UDim2.new(0, 0, 0, 28)
        bar.BackgroundColor3 = Color3.fromRGB(25, 35, 25)
        bar.Parent = container
        createCorner(bar, 3)

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(default, 0, 1, 0)
        fill.BackgroundColor3 = Color3.fromRGB(80, 255, 120)
        fill.Parent = bar
        createCorner(fill, 3)

        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 14, 0, 14)
        knob.Position = UDim2.new(default, -7, 0.5, -7)
        knob.BackgroundColor3 = Color3.fromRGB(220, 255, 230)
        knob.Parent = bar
        createCorner(knob, 7)

        local draggingSlider = false

        local function update(v)
            v = math.clamp(v, 0, 1)
            fill.Size = UDim2.new(v, 0, 1, 0)
            knob.Position = UDim2.new(v, -7, 0.5, -7)
            valueLabel.Text = math.floor(v * 100) .. "%"
            onChange(v)
        end

        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = true
                update((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                update((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = false
            end
        end)
    end

    createSlider(45, "Steal Speed", stealSpeedValue, 50, 100, function(v) stealSpeedValue = v end)
    createSlider(105, "Trigger Percent", triggerValue, 50, 100, function(v) triggerValue = v end)
end

-- ==================== FUNCTIONALITY ====================
local function setupFunctionality(SettingsBtn)
    -- Draggable
    local dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            dragInput = input
        end
    end)

    MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    -- Settings Button Logic
    SettingsBtn.MouseButton1Click:Connect(function()
        if SettingsFrame.Visible then
            SettingsFrame.Visible = false
            MainFrame.Visible = true
        else
            MainFrame.Visible = false
            SettingsFrame.Visible = true
            SettingsFrame.Position = MainFrame.Position
        end
    end)

    -- Gradient Animation
    local stroke = MainFrame:FindFirstChildWhichIsA("UIStroke")
    local grad = stroke and stroke:FindFirstChildWhichIsA("UIGradient")
    if grad then
        RunService.Heartbeat:Connect(function(dt)
            grad.Rotation = (grad.Rotation + CONFIG.Accent.GradientRotationSpeed * 60 * dt) % 360
        end)
    end

    -- Proximity Prompt (Steal)
    ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
        if activeTriggers[prompt] then return end
        activeTriggers[prompt] = true

        local startTime = os.clock()
        local fired = false
        local conn

        conn = RunService.PreRender:Connect(function()
            if not prompt or not prompt.Parent then
                conn:Disconnect()
                activeTriggers[prompt] = nil
                return
            end

            local progress = (os.clock() - startTime) / prompt.HoldDuration

            if not fired and progress >= triggerValue then
                fired = true
                conn:Disconnect()
                activeTriggers[prompt] = nil

                local char = LocalPlayer.Character
                local tool = char and char:FindFirstChildOfClass("Tool")
                if tool and stealSpeedEnabled then
                    tool:Activate()
                end
            end
        end)

        prompt.PromptButtonHoldEnded:Connect(function()
            if not fired then
                conn:Disconnect()
                activeTriggers[prompt] = nil
            end
        end)
    end)
end

-- Initialize
local SettingsBtn = createMainGUI()
createSettingsGUI()
setupFunctionality(SettingsBtn)

print("[Meowl Hub] Steal Script Loaded! ✅")
