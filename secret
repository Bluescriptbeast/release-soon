local RIGHT_PATH = {
    {pos = Vector3.new(-474,-7,23),  speed = 55},
    {pos = Vector3.new(-484,-5,24),  speed = 55},
    {pos = Vector3.new(-488,-5,24),  speed = 55},
    {pos = Vector3.new(-493,-5,25),  speed = 55},
    {pos = Vector3.new(-473,-7,25),  speed = 29},
    {pos = Vector3.new(-474,-7,112), speed = 29},
}

local function stopAutoMove()
    if AutoMove.Connection then
        AutoMove.Connection:Disconnect()
        AutoMove.Connection = nil
    end
    local root = getHRP()
    if root then root.Velocity = Vector3.zero end
end

local function runPath(path)
    stopAutoMove()
    local idx = 1
    AutoMove.Connection = RunService.Stepped:Connect(function()
        local root = getHRP()
        if not root then stopAutoMove() return end

        local wp = path[idx]
        if not wp then stopAutoMove() return end

        if (root.Position - wp.pos).Magnitude < 5 then
            idx += 1
            if idx > #path then
                task.wait(AutoMove.Delay)
                idx = 1
            end
        else
            local dir = (wp.pos - root.Position).Unit
            root.Velocity = Vector3.new(dir.X * wp.speed, root.Velocity.Y, dir.Z * wp.speed)
        end
    end)
end

