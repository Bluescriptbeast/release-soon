local function saveConfig()
    local data = {
        flashEnabled = flashEnabled,
        sliderValue = sliderValue,
        potionEnabled = potionEnabled,
        effectEnabled = effectEnabled,
        effectPower = effectPower,
        playerEsp = playerEsp,
        lowGraphics = lowGraphics,
        espBrainrot = espBrainrot,
        fovEnabled = fovEnabled,
        currentFov = currentFov,
    }
    local success, err = pcall(function()
        writefile("KrimoHub_Config.json", game:GetService("HttpService"):JSONEncode(data))
    end)
    if success then
        print("✅ Krimo Hub Config saved!")
    end
    return success
end

local function loadConfig()
    local success, data = pcall(function()
        if not isfile("KrimoHub_Config.json") then return nil end
        local content = readfile("KrimoHub_Config.json")
        return game:GetService("HttpService"):JSONDecode(content)
    end)
    if success and data then
        flashEnabled = data.flashEnabled ~= nil and data.flashEnabled or true
        sliderValue = data.sliderValue or 0.92
        potionEnabled = data.potionEnabled or false
        effectEnabled = data.effectEnabled or false
        effectPower = data.effectPower or 50
        playerEsp = data.playerEsp or false
        lowGraphics = data.lowGraphics or false
        espBrainrot = data.espBrainrot or false
        fovEnabled = data.fovEnabled or false
        currentFov = data.currentFov or 70
        print("✅ Krimo Hub Config loaded!")
        return true
    end
    print("No saved config found, using defaults")
    return false
end

