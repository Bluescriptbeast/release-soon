-- ==================== PROGRESS BAR ANIMATION ====================
local function animateProgressBar(duration)
    if not ProgressFill then return end
    ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local goal = {Size = UDim2.new(1, 0, 1, 0)}
    local tween = game:GetService("TweenService"):Create(ProgressFill, tweenInfo, goal)
    tween:Play()
    
    tween.Completed:Connect(function()
        task.wait(0.1)
        ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    end)
end

-- ==================== AUTO HOLD (Örnek Script Entegre) ====================
local function setupAutoHold()
    ProximityPromptService.PromptShown:Connect(function(prompt)
        if not autoFlashEnabled then return end
        if activeTriggers[prompt] then return end
        activeTriggers[prompt] = true

        prompt.HoldDuration = 0.01 -- Hızlı tamamlamak için

        task.spawn(function()
            task.wait(0.03)
            animateProgressBar(prompt.HoldDuration) -- Görsel efekt
            prompt:InputHoldBegin()
            
            task.wait(prompt.HoldDuration + 0.05)
            prompt:InputHoldEnd()
            
            activeTriggers[prompt] = nil
        end)
    end)
end

-- ==================== FUNCTIONS ====================
local function setupFunctionality(SettingsBtn, CloseBtn)
    makeDraggable(MainFrame)
    makeDraggable(SettingsFrame)

    SettingsBtn.MouseButton1Click:Connect(function()
        if SettingsFrame.Visible then
            SettingsFrame.Visible = false
            MainFrame.Visible = true
        else
            SettingsFrame.Position = MainFrame.Position
            SettingsFrame.Visible = true
            MainFrame.Visible = false
        end
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        MainFrame.Position = SettingsFrame.Position
        SettingsFrame.Visible = false
        MainFrame.Visible = true
    end)

    -- Gradient
    local stroke = MainFrame:FindFirstChildWhichIsA("UIStroke")
    local grad = stroke and stroke:FindFirstChildWhichIsA("UIGradient")
    if grad then
        RunService.Heartbeat:Connect(function(dt)
            grad.Rotation = (grad.Rotation + CONFIG.Accent.GradientRotationSpeed * 60 * dt) % 360
        end)
    end
end

