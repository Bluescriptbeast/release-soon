-- --- CORE SYSTEM LOGIC ---

-- Target Aggression Validation
local function getClosestPlayer()
	local closestPlayer = nil
	local shortestDistance = math.huge
	local myChar = LocalPlayer.Character
	if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local distance = (myChar.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
			if distance < shortestDistance then
				shortestDistance = distance
				closestPlayer = player
			end
		end
	end
	return closestPlayer
end

-- Force Inventory Equips
local function equipBat()
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	local character = LocalPlayer.Character
	if backpack and character then
		local bat = backpack:FindFirstChild("Bat") or character:FindFirstChild("Bat")
		if bat and bat.Parent ~= character then
			bat.Parent = character
		end
	end
end

-- Visual Switch Manipulator
local function updateToggleVisuals()
	if isToggled then
		ToggleBall:TweenPosition(UDim2.new(1, -19, 0, 2), "Out", "Quad", 0.12, true)
		ToggleBall.BackgroundColor3 = Color3.fromRGB(180, 180, 180) -- Active highlight state
	else
		ToggleBall:TweenPosition(UDim2.new(0, 3, 0, 2), "Out", "Quad", 0.12, true)
		ToggleBall.BackgroundColor3 = Color3.fromRGB(55, 55, 55)  -- Dark grey baseline state
	end
end

-- Global Logic Variable Swapper
local function setToggleState(state)
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	
	if state == isToggled then return end
	isToggled = state
	updateToggleVisuals()
	
	if isToggled then
		if hrp then
			savedPosition = hrp.CFrame
		end
	else
		if savedPosition and hrp then
			hrp.CFrame = savedPosition
		end
	end
end


