   local relY = 10 + row * (QS + QG)

   -- Outer glow halo (warm brown, soft)
   local halo1 = Instance.new("Frame", mbGroup)
   halo1.Size = UDim2.new(0, QS + 12, 0, QS + 12)
   halo1.Position = UDim2.new(0, relX - 6, 0, relY - 6)
