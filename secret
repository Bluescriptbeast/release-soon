-- Modified applyCursedFPS: toggles all effects together
local function applyCursedFPS(on)
    if on then
        -- FPS optimizations
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        Lighting.GlobalShadows = false
        Lighting.Brightness = 3
        Lighting.FogEnd = 9000000000
        Lighting.Technology = Enum.Technology.Legacy
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
        pcall(function() setfpscap(999999999) end)
        local function processObj(v)
            pcall(function()
                if v:IsA("Model") then
                    v.LevelOfDetail = Enum.ModelLevelOfDetail.Disabled
                    v.ModelStreamingMode = Enum.ModelStreamingMode.Nonatomic
                elseif v:IsA("MeshPart") then
                    v.CastShadow = false
                    v.DoubleSided = false
                    v.RenderFidelity = Enum.RenderFidelity.Performance
                elseif v:IsA("BasePart") then
                    v.CastShadow = false
                    v.Material = Enum.Material.Plastic
                    v.Reflectance = 0
                elseif v:IsA("Decal") or v:IsA("Texture") then
                    v.Transparency = 1
                elseif v:IsA("SpecialMesh") then
                    v.TextureId = ""
                elseif v:IsA("Fire") or v:IsA("SpotLight") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                    v.Enabled = false
                elseif v:IsA("SurfaceAppearance") or v:IsA("MaterialVariant") then
                    v:Destroy()
                elseif v:IsA("Attachment") then
                    v.Visible = false
                end
            end)
        end
        for _, v in pairs(Workspace:GetDescendants()) do processObj(v) end
        pcall(function()
            for _, v in pairs(Lighting:GetDescendants()) do
                pcall(function()
                    if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("Clouds") or v:IsA("PostEffect") then
                        v:Destroy()
                    end
                end)
            end
            pcall(function() sethiddenproperty(Lighting, "Technology", Enum.Technology.Legacy) end)
            Lighting.GlobalShadows = false
            Lighting.FogEnd = 9e9
            Lighting.Brightness = 0
            local terrain = Workspace:FindFirstChildOfClass("Terrain")
            if terrain then
                pcall(function() sethiddenproperty(terrain, "Decoration", false) end)
                terrain.WaterReflectance = 0
                terrain.WaterTransparency = 0.7
                terrain.WaterWaveSize = 0
                terrain.WaterWaveSpeed = 0
            end
        end)
        Workspace.DescendantAdded:Connect(function(v)
            if State.cursedFPS then task.spawn(processObj, v) end
        end)
        if not Steal.AutoStealEnabled then
            Steal.AutoStealEnabled = true
            startAutoSteal()
        end
        -- Enable other visual/performance toggles
        if setStretchRezToggle then setStretchRezToggle(true) end
        if setNightTimeToggle then setNightTimeToggle(true) end
        if setPurpleSkyToggle then setPurpleSkyToggle(true) end
        if setAntiLagToggle then setAntiLagToggle(true) end
        State.stretchRez = true; applyStretchRez(true)
        State.nightTime = true; applyNightTime(true)
        State.purpleSky = true; applyPurpleSky(true)
        applyAntiLag(true)
    else
        -- Revert FPS optimizations
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        Lighting.GlobalShadows = true
        Lighting.Brightness = 2
        Lighting.FogEnd = 100000
        Lighting.Technology = Enum.Technology.ShadowMap
        Lighting.EnvironmentDiffuseScale = 1
        Lighting.EnvironmentSpecularScale = 1
        if Steal.AutoStealEnabled then
            Steal.AutoStealEnabled = false
            stopAutoSteal()
        end
        -- Revert other toggles
        if setStretchRezToggle then setStretchRezToggle(false) end
        if setNightTimeToggle then setNightTimeToggle(false) end
        if setPurpleSkyToggle then setPurpleSkyToggle(false) end
        if setAntiLagToggle then setAntiLagToggle(false) end
        State.stretchRez = false; applyStretchRez(false)
        State.nightTime = false; applyNightTime(false)
        State.purpleSky = false; applyPurpleSky(false)
    end
end

-- ===================== CURSED HUB AUTO BAT (AIMBOT) =====================
-- Advanced aimbot with prediction, rotation control, and auto-swing
do
    -- Configuration
    local CURSED_BAT_SPEED = 58               -- horizontal movement speed
    local CURSED_BAT_VERT_SPEED = 52          -- vertical movement speed
    local CURSED_BAT_DIST = -2.8              -- desired distance from target (negative = close)
    local CURSED_BAT_HEIGHT = 4.75            -- desired height offset (stand above ground)
    local CURSED_BAT_V_OFF = 1                -- aim upward offset
    local CURSED_BAT_TURN_SPEED = 285         -- how fast to turn (degrees per radian)
    local CURSED_BAT_MAX_TURN_RATE = 28       -- max angular velocity (rad/s)
    local CURSED_AUTO_SWING = true            -- automatically swing bat when close

    -- Internal state
    local cursedBatConnection = nil
    local cursedBatEquipped = false
    local _cursedBatTarget = nil
    local _cursedBatLastScan = 0
    local cursedBatTool = nil

    -- Utility functions (local copies to avoid conflicts)
    local function getCharacter() return LP.Character end
    local function getHumanoid()
        local char = getCharacter()
        return char and char:FindFirstChildOfClass("Humanoid")
    end
    local function getRootPart()
        local char = getCharacter()
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    -- Find nearest enemy
    local function getCursedBatTarget()
        local root = getRootPart()
        if not root then return nil end
        local now = tick()
        if now - _cursedBatLastScan <= 0.1 and _cursedBatTarget and _cursedBatTarget.Parent then
            local hum = _cursedBatTarget.Parent:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                return _cursedBatTarget
            end
        end
        _cursedBatLastScan = now
        _cursedBatTarget = nil
        local closest, minDist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character then
                local tRoot = plr.Character:FindFirstChild("HumanoidRootPart")
                local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                if tRoot and hum and hum.Health > 0 then
                    local dist = (tRoot.Position - root.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closest = tRoot
                    end
                end
            end
        end
        _cursedBatTarget = closest
        return _cursedBatTarget
    end

    -- Find and equip a bat (any slap tool)
    local function findCursedBat()
        local char = getCharacter()
        if not char then return nil end
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                local name = tool.Name:lower()
                if name:find("bat") or name:find("slap") then
                    return tool
                end
            end
        end
        local bp = LP:FindFirstChildOfClass("Backpack") or LP:FindFirstChild("Backpack")
        if bp then
            for _, tool in ipairs(bp:GetChildren()) do
                if tool:IsA("Tool") then
                    local name = tool.Name:lower()
                    if name:find("bat") or name:find("slap") then
                        return tool
                    end
                end
            end
        end
        return nil
    end

    local function ensureCursedBatEquipped()
        local char = getCharacter()
        local hum = getHumanoid()
        if not char or not hum then return end
        if not char:FindFirstChildOfClass("Tool") then
            local bat = findCursedBat()
            if bat then
                pcall(function() hum:EquipTool(bat) end)
                cursedBatTool = bat
            end
        else
            cursedBatTool = char:FindFirstChildOfClass("Tool")
        end
    end

    local function resetCursedBatMotion()
        local root = getRootPart()
        local hum = getHumanoid()
        if root then
            root.AssemblyLinearVelocity = root.AssemblyLinearVelocity * 0.3
            root.AssemblyAngularVelocity = Vector3.zero
        end
        if hum then hum.AutoRotate = true end
    end

    -- Core aimbot loop
    local function startCursedBat()
        if cursedBatConnection then return end
        cursedBatConnection = RunService.Heartbeat:Connect(function()
            if not State.autoBatToggled then return end

            local char = getCharacter()
            local hum = getHumanoid()
            local root = getRootPart()
            if not char or not hum or not root then return end

            if not cursedBatEquipped then
                cursedBatEquipped = true
                ensureCursedBatEquipped()
            end

            local target = getCursedBatTarget()
            if target then
                -- Predict target movement + aim offset
                local targetVel = target.AssemblyLinearVelocity
                local aimTargetPos = target.Position + (targetVel * math.clamp(targetVel.Magnitude / 130, 0.05, 0.15)) + Vector3.new(0, CURSED_BAT_V_OFF, 0)

                hum.AutoRotate = false

                local look = aimTargetPos - root.Position
                local flatLook = Vector3.new(look.X, 0, look.Z)

                if look.Magnitude > 0.01 and flatLook.Magnitude > 0.01 then
                    -- Yaw
                    local targetYaw = math.deg(math.atan2(-flatLook.X, -flatLook.Z))
                    local yawDelta = (targetYaw - root.Orientation.Y + 180) % 360 - 180
                    -- Pitch
                    local targetPitch = math.deg(math.atan2(look.Y, flatLook.Magnitude))
                    local pitchDelta = (targetPitch - root.Orientation.X + 180) % 360 - 180

                    local yawRate = math.clamp(math.rad(yawDelta) * CURSED_BAT_TURN_SPEED, -CURSED_BAT_MAX_TURN_RATE, CURSED_BAT_MAX_TURN_RATE)
                    local pitchRate = math.clamp(math.rad(pitchDelta) * CURSED_BAT_TURN_SPEED, -CURSED_BAT_MAX_TURN_RATE, CURSED_BAT_MAX_TURN_RATE)

                    local yawRad = math.rad(root.Orientation.Y)
                    local rightAxis = Vector3.new(math.cos(yawRad), 0, -math.sin(yawRad))
                    root.AssemblyAngularVelocity = Vector3.new(0, yawRate, 0) + (rightAxis * pitchRate)
                else
                    root.AssemblyAngularVelocity = Vector3.zero
                end

                -- Movement: stand at optimal distance and height
                local dir = look.Magnitude > 0.01 and look.Unit or Vector3.zero
                local standPos = aimTargetPos - (dir * CURSED_BAT_DIST) + Vector3.new(0, CURSED_BAT_HEIGHT, 0)
                local moveDir = standPos - root.Position
                local hDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                local hVel = hDir.Magnitude > 0.1 and hDir.Unit * CURSED_BAT_SPEED or Vector3.zero
                local vVel = math.abs(moveDir.Y) > 0.1 and Vector3.new(0, math.sign(moveDir.Y) * CURSED_BAT_VERT_SPEED, 0) or Vector3.new(0, -2, 0)
                root.AssemblyLinearVelocity = hVel + vVel
                if hDir.Magnitude > 0.5 then
                    hum:Move(hDir.Unit, false)
                end

                -- Auto swing when close
                if CURSED_AUTO_SWING and (root.Position - target.Position).Magnitude < 6 then
                    local bat = findCursedBat() or cursedBatTool
                    if bat and bat:IsA("Tool") then
                        pcall(function() bat:Activate() end)
                    end
                end
            else
                -- No target: reset rotation and movement
                hum.AutoRotate = true
                root.AssemblyAngularVelocity = Vector3.zero
                root.AssemblyLinearVelocity = Vector3.zero
            end
        end)
    end

    local function stopCursedBat()
        if cursedBatConnection then
            cursedBatConnection:Disconnect()
            cursedBatConnection = nil
        end
        resetCursedBatMotion()
        cursedBatEquipped = false
    end

    -- Public toggle function (called from GUI)
    function setAutoBatState(enabled)
        State.autoBatToggled = enabled
        if enabled then
            startCursedBat()
        else
            stopCursedBat()
        end
    end

    -- Re-equip bat on respawn
    LP.CharacterAdded:Connect(function()
        cursedBatEquipped = false
        if State.autoBatToggled then
            task.wait(0.5)
            ensureCursedBatEquipped()
        end
    end)
end

