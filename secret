                if AutoSteal.heartbeatConn then AutoSteal.heartbeatConn:Disconnect() end
            end
        end

        if text == "Auto Left" then
            autoLeft = enabled
            if enabled then
                task.spawn(function()
                    go(A1_P1, SPEED_NORMAL, function() return autoLeft end)
                    go(A1_P2, SPEED_NORMAL, function() return autoLeft end)
                    instaGrab = true
                    go(A1_P3, SPEED_CARRY, function() return autoLeft end)
