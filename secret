local function getPotion()
    local char = player.Character
    local backpack = player:FindFirstChild("Backpack")
    return (char and char:FindFirstChild("Giant Potion")) or (backpack and backpack:FindFirstChild("Giant Potion"))
end

local function useGiantPotion()
    local char = player.Character or player.CharacterAdded:Wait()
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return false end
    local tool = getPotion()
    if tool then
        humanoid:EquipTool(tool)
        task.wait(0.05)
        tool:Activate()
        return true
    end
    return false
end

local function useFlashTP()
    if not flashTPEnabled then return end
    local char = player.Character
    local flashTool = char and char:FindFirstChild("Flash Teleport")
    if not flashTool then
        local backpack = player:FindFirstChild("Backpack")
        if backpack then flashTool = backpack:FindFirstChild("Flash Teleport") end
    end
    if flashTool then
        if flashTool.Parent ~= char then
            flashTool.Parent = char
            task.wait(0.05)
        end
        pcall(function() flashTool:Activate() end)
    end
end

local function alignCamera()
    local camera = workspace.CurrentCamera
    if not camera then return end
    local cf = camera.CFrame
    local pitch = math.rad(28.4)
    local newLook = Vector3.new(cf.LookVector.X, math.sin(pitch), cf.LookVector.Z)
    camera.CFrame = CFrame.new(cf.Position, cf.Position + newLook)
end

local function updateStealBar(progress)
    StealBarFill:TweenSize(UDim2.new(progress, 0, 1, 0), "Out", "Linear", 0.05, true)
end

ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
    if activePrompts[prompt] then return end
    activePrompts[prompt] = true
    local startTime = tick()
    local triggerPercent = triggerValue / 100
    local hasUsedGiantPotion = false

    local connection = RunService.Heartbeat:Connect(function()
        if not prompt or not prompt.Parent then
            connection:Disconnect()
            activePrompts[prompt] = nil
            updateStealBar(0)
            return
        end
        local elapsed = tick() - startTime
        local progress = math.min(elapsed / prompt.HoldDuration, 1)
        updateStealBar(progress)
        if progress >= triggerPercent then
            connection:Disconnect()
            activePrompts[prompt] = nil
            if flashTPEnabled then task.spawn(useFlashTP) end
            if giantPotionEnabled and not hasUsedGiantPotion then
                hasUsedGiantPotion = true
                task.spawn(function()
                    local success = useGiantPotion()
                    if success then
                        task.wait(0.05)
                        if RealAPRemote then
                            pcall(function() RealAPRemote:InvokeServer("f888ee6e-c86d-46e1-93d7-0639d6635d42", player, "ragdoll") end)
                        end
                    end
                end)
            end
            updateStealBar(1)
            task.delay(0.2, function() updateStealBar(0) end)
            if kickAfterStealEnabled then
                task.wait(0.4)
                kickPlayer()
            end
        end
    end)

    prompt.PromptButtonHoldEnded:Connect(function()
        if connection and connection.Connected then
            connection:Disconnect()
            activePrompts[prompt] = nil
            updateStealBar(0)
        end
    end)
end)

local GRAVITY_MULTIPLIER = 0.4
local counterForce = (1 - GRAVITY_MULTIPLIER) * workspace.Gravity * 0.52

local function applyLowGravity()
    if not zeroGravityEnabled then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        local vel = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(vel.X, vel.Y + counterForce * 0.016, vel.Z)
    end
end

local function startZeroGravity()
    if zeroGravityConnection then zeroGravityConnection:Disconnect() end
    zeroGravityConnection = RunService.Heartbeat:Connect(applyLowGravity)
end

local function stopZeroGravity()
    if zeroGravityConnection then
        zeroGravityConnection:Disconnect()
        zeroGravityConnection = nil
    end
end

