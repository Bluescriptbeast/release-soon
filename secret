        status1.Text = "ENABLED"
        TweenService:Create(status1, tweenInfo, {TextColor3 = Color3.fromRGB(0, 255, 0)}):Play()
        TweenService:Create(toggle1, tweenInfo, {BackgroundColor3 = Color3.fromRGB(0, 60, 0)}):Play()
        TweenService:Create(knob1, tweenInfo, {BackgroundColor3 = Color3.fromRGB(0, 255, 0)}):Play()
        TweenService:Create(knob1, tweenInfo, {Position = UDim2.new(0, 24, 0.5, -7)}):Play()
    else
        TweenService:Create(card1Stroke, tweenInfo, {Color = Color3.fromRGB(0, 80, 0)}):Play()
        status1.Text = "DISABLED"
        TweenService:Create(status1, tweenInfo, {TextColor3 = Color3.fromRGB(0, 150, 0)}):Play()
