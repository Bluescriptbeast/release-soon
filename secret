local function createCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
end

local function createStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(80, 255, 120)
    s.Thickness = thickness or 1.5
    s.Parent = parent
    return s
end

local function createGradient(parent)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(0, 25, 10)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(80, 255, 120)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(0, 25, 10)),
    }
    g.Parent = parent
    return g
end

local function makeDraggable(frame)
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            dragInput = input
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

local function getPingBase(ping)
    if ping <= 30 then return 0.91
    elseif ping <= 70 then return 0.92
    elseif ping <= 120 then return 0.93
    else return 0.94 end
end

-- Yeni Toggle Oluşturma Fonksiyonu (Aries Stili)
local function CreateToggle(name, configKey, hasInput, defaultVal, parent)
    local Row = Instance.new("Frame")
    local Label = Instance.new("TextLabel")
    local ToggleBtn = Instance.new("TextButton")
    local Circle = Instance.new("Frame")
    
    Row.Name = name
    Row.Parent = parent
    Row.BackgroundTransparency = 1
    Row.Size = UDim2.new(1, -20, 0, 45)

    Label.Parent = Row
    Label.BackgroundTransparency = 1
    Label.Size = UDim2.new(0.55, 0, 1, 0)
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.Font = Enum.Font.GothamBold
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(180, 255, 200)
    Label.TextSize = 14
    Label.TextXAlignment = Enum.TextXAlignment.Left

    ToggleBtn.Parent = Row
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 45, 35)
    ToggleBtn.Position = UDim2.new(0.68, 0, 0.2, 0)
    ToggleBtn.Size = UDim2.new(0, 50, 0, 26)
    ToggleBtn.Text = ""
    local btnCorner = Instance.new("UICorner", ToggleBtn)
    btnCorner.CornerRadius = UDim.new(1, 0)

    Circle.Parent = ToggleBtn
    Circle.BackgroundColor3 = Toggles[configKey] and CONFIG.Toggle.OnColor or Color3.fromRGB(80, 80, 80)
    Circle.Position = Toggles[configKey] and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
    Circle.Size = UDim2.new(0, 20, 0, 20)
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

    ToggleBtn.MouseButton1Click:Connect(function()
        Toggles[configKey] = not Toggles[configKey]
        Circle.BackgroundColor3 = Toggles[configKey] and CONFIG.Toggle.OnColor or Color3.fromRGB(80, 80, 80)
        Circle:TweenPosition(
            Toggles[configKey] and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10),
            "Out", "Quad", 0.25, true
        )
    end)

    if hasInput then
        local Input = Instance.new("TextBox")
        Input.Parent = Row
        Input.BackgroundColor3 = Color3.fromRGB(20, 35, 25)
        Input.Position = UDim2.new(0.85, 0, 0.2, 0)
        Input.Size = UDim2.new(0, 55, 0, 26)
        Input.Font = Enum.Font.GothamBold
        Input.Text = tostring(defaultVal)
        Input.TextColor3 = Color3.fromRGB(200, 255, 220)
        Input.TextSize = 13
        Instance.new("UICorner", Input).CornerRadius = UDim.new(0, 6)
        
        Input.FocusLost:Connect(function()
            if configKey == "FlashTP" then
                Values.TPDistance = tonumber(Input.Text) or defaultVal
            else
                Values.SpeedAmount = tonumber(Input.Text) or defaultVal
            end
        end)
    end

    return Row
end

