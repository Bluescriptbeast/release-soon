-- Variables
local antibatactive = false
local antibatconn = nil
local infJumpEnabled = false
local jumpConnection = nil
local fallConnection = nil

local INF_JUMP_FORCE = 54
local CLAMP_FALL = 80

local function getHRP()
    local char = LocalPlayer.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

-- ====================== ANTI BAT ======================
local function startAntiBat()
    if antibatconn then antibatconn:Disconnect() end
    
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    antibatconn = RunService.Heartbeat:Connect(function()
        if not root or not root.Parent then return end
        
        local vel = root.AssemblyLinearVelocity
        local origX, origZ = vel.X, vel.Z
        
        -- Anti-Bat (Velocity Spike)
        root.AssemblyLinearVelocity = Vector3.new(1000, vel.Y, 1000)
        
        RunService.RenderStepped:Wait()
        
        vel = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(origX, vel.Y, origZ)
    end)
end

local function stopAntiBat()
    if antibatconn then
        antibatconn:Disconnect()
        antibatconn = nil
    end
end

-- ====================== INFINITY JUMP ======================
local function applyInfJump()
    if jumpConnection then jumpConnection:Disconnect() end
    if fallConnection then fallConnection:Disconnect() end

    jumpConnection = UserInputService.JumpRequest:Connect(function()
        if not infJumpEnabled then return end
        local hrp = getHRP()
        if not hrp then return end
        
        local vel = hrp.AssemblyLinearVelocity
        hrp.AssemblyLinearVelocity = Vector3.new(vel.X, INF_JUMP_FORCE, vel.Z)
    end)

    fallConnection = RunService.Heartbeat:Connect(function()
        if not infJumpEnabled then return end
        local hrp = getHRP()
        if not hrp then return end
        
        local vel = hrp.AssemblyLinearVelocity
        if vel.Y < -CLAMP_FALL then
            hrp.AssemblyLinearVelocity = Vector3.new(vel.X, -CLAMP_FALL, vel.Z)
        end
    end)
end

local function toggleInfJump(state)
    infJumpEnabled = state
    if state then
        applyInfJump()
    else
        if jumpConnection then jumpConnection:Disconnect() end
        if fallConnection then fallConnection:Disconnect() end
    end
end

