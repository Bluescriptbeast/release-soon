local function updateSliderVisual(v)
    sliderValue = math.clamp(v, 0, 1)
    SliderFill.Size = UDim2.new(sliderValue, 0, 1, 0)
    SliderKnob.Position = UDim2.new(sliderValue, -6, 0.5, -6)
    SliderRightLabel.Text = math.floor(sliderValue * 100) .. "%"
end

local function setupSlider()
    SliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            manualOverride = true
            draggingSlider = true
            updateSliderVisual((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSliderVisual((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = false
        end
    end)
end

local function setupFunctionality()
    makeDraggable(MainFrame)
    setupSlider()

    -- Gradient Animation
    if CONFIG.Accent.GradientRotationSpeed ~= 0 then
        local stroke = MainFrame:FindFirstChildWhichIsA("UIStroke")
        local grad = stroke and stroke:FindFirstChildWhichIsA("UIGradient")
        if grad then
            RunService.Heartbeat:Connect(function(dt)
                grad.Rotation = (grad.Rotation + CONFIG.Accent.GradientRotationSpeed * 60 * dt) % 360
            end)
        end
    end

    -- Auto Flash Toggle
    ToggleButton.MouseButton1Click:Connect(function()
        flashEnabled = not flashEnabled
        StatusLabel.Text = flashEnabled and "ON" or "OFF"
        StatusLabel.TextColor3 = flashEnabled and CONFIG.Toggle.OnColor or CONFIG.Toggle.OffColor
    end)

    -- Ping Based Slider Update
    RunService.Heartbeat:Connect(function()
        if not manualOverride then
            local ping = LocalPlayer:GetNetworkPing() * 1000
            local base = getPingBase(ping)
            updateSliderVisual(triggerBump and base + 0.01 or base)
        end
    end)

    -- Auto Flash Logic
    ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
        if not flashEnabled then return end
        if activeTriggers[prompt] then return end
        activeTriggers[prompt] = true
        local start = os.clock()
        local fired = false

        local conn
        conn = RunService.PreRender:Connect(function()
            if not prompt or not prompt.Parent then
                conn:Disconnect()
                activeTriggers[prompt] = nil
                return
            end
            if not fired and (os.clock() - start) / prompt.HoldDuration >= sliderValue then
                fired = true
                conn:Disconnect()
                activeTriggers[prompt] = nil
                triggerBump = not triggerBump
                local char = LocalPlayer.Character
                local tool = char and char:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end)

        prompt.PromptButtonHoldEnded:Connect(function()
            if not fired then
                conn:Disconnect()
                activeTriggers[prompt] = nil
            end
        end)
    end)

    -- Speed Boost + Other Features
    RunService.RenderStepped:Connect(function()
        local Character = LocalPlayer.Character
        if not Character or not Character:FindFirstChild("Humanoid") then return end

        -- Speed Boost
        if Toggles.SpeedBoost then
            Character.Humanoid.WalkSpeed = Values.SpeedAmount
        else
            Character.Humanoid.WalkSpeed = 16
        end

        -- Auto Potion (Basit örnek - oyuna göre uyarla)
        if Toggles.AutoPotion then
            -- Potion logic buraya eklenebilir
        end

        -- Align (Su)
        if Toggles.Align then
            local hrp = Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.rad(90), 0) -- Örnek align
            end
        end
    end)

    -- Flash TP
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.V and Toggles.FlashTP then
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -Values.TPDistance)
            end
        end
    end)

    -- Kick After Steal (Örnek - oyuna göre uyarla)
    -- Bu kısım oyunun spesifik event'lerine göre değiştirilmelidir
end

createGUI()
