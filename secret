        bar.Size = UDim2.new(1, 0, 0, 6)
        bar.Position = UDim2.new(0, 0, 0, 26)
        bar.BackgroundColor3 = Color3.fromRGB(25, 35, 25)
        bar.Parent = container
        createCorner(bar, 3)
        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(default / maxVal, 0, 1, 0)
        fill.BackgroundColor3 = Color3.fromRGB(80, 255, 120)
        fill.Parent = bar
        createCorner(fill, 3)
        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 14, 0, 14)
        knob.Position = UDim2.new(default / maxVal, -7, 0.5, -7)
        knob.BackgroundColor3 = Color3.fromRGB(220, 255, 230)
        knob.Parent = bar
        createCorner(knob, 7)
        local dragging = false
        local function update(v)
            v = math.clamp(v, 0, 1)
            local val = math.floor(v * maxVal)
            fill.Size = UDim2.new(v, 0, 1, 0)
            knob.Position = UDim2.new(v, -7, 0.5, -7)
            valueLabel.Text = tostring(val) .. (isPercent and "%" or "")
            onChange(val)
        end
        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                update((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                update((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
    end
    createSlider(118, "Trigger Percent", math.floor(triggerValue * 100), 100, true, function(v) triggerValue = v / 100 end)
    return CloseBtn
end

local function setupAutoFlash()
    ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
        if not autoFlashEnabled then return end
        if activeTriggers[prompt] then return end
        activeTriggers[prompt] = true
        local start = os.clock()
        local fired = false
        local conn
        animateProgressBar()
        conn = RunService.PreRender:Connect(function()
            if not prompt or not prompt.Parent then
                conn:Disconnect()
                activeTriggers[prompt] = nil
                resetProgressBar()
                return
            end
            local progress = (os.clock() - start) / HOLD_ANIMATION_TIME
            if not fired and progress >= triggerValue then
                fired = true
                conn:Disconnect()
                activeTriggers[prompt] = nil
                local char = LocalPlayer.Character
                local tool = char and char:FindFirstChildOfClass("Tool")
                if tool then
                    tool:Activate()
                end
                task.delay(0.3, resetProgressBar)
            end
        end)
        prompt.PromptButtonHoldEnded:Connect(function()
            if not fired then
                conn:Disconnect()
                activeTriggers[prompt] = nil
                resetProgressBar()
            end
        end)
    end)
end

local function setupAutoPotion()
    spawn(function()
        while true do
            if autoPotionEnabled then
                local char = LocalPlayer.Character
                if char then
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool and tool.Name:lower():find("potion") then
                        tool:Activate()
                    end
                end
            end
            task.wait(0.8)
        end
    end)
end

local function setupFunctionality(SettingsBtn, CloseBtn)
    makeDraggable(MainFrame)
    makeDraggable(SettingsFrame)
    SettingsBtn.MouseButton1Click:Connect(function()
        if SettingsFrame.Visible then
            SettingsFrame.Visible = false
            MainFrame.Visible = true
        else
            SettingsFrame.Position = MainFrame.Position
            SettingsFrame.Visible = true
            MainFrame.Visible = false
        end
    end)
    CloseBtn.MouseButton1Click:Connect(function()
        MainFrame.Position = SettingsFrame.Position
        SettingsFrame.Visible = false
        MainFrame.Visible = true
    end)
    local stroke = MainFrame:FindFirstChildWhichIsA("UIStroke")
    local grad = stroke and stroke:FindFirstChildWhichIsA("UIGradient")
    if grad then
        RunService.Heartbeat:Connect(function(dt)
            grad.Rotation = (grad.Rotation + CONFIG.Accent.GradientRotationSpeed * 60 * dt) % 360
        end)
    end
end

