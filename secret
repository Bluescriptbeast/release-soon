   lbl.TextXAlignment = Enum.TextXAlignment.Center
   lbl.TextYAlignment = Enum.TextYAlignment.Center
   lbl.ZIndex = 105
   local txtStroke = Instance.new("UIStroke", lbl)
   txtStroke.Color = Color3.fromRGB(200, 160, 110)
   txtStroke.Thickness = 1.2
   txtStroke.Transparency = 0.1

   -- Pulse connection (when toggle is ON)
   local active = false
   local pulseConn = nil

   local function setActive(state)
      active = state
      if active then
         if pulseConn then pulseConn:Disconnect(); pulseConn = nil end
         pulseConn = RunService.Heartbeat:Connect(function()
            local t = tick() * 2.2
            local pulse = math.sin(t) * 0.5 + 0.5
            local r = math.floor(180 + pulse * 55)
            local g = math.floor(110 + pulse * 45)
            local b = math.floor(40 + pulse * 20)
            local col = Color3.fromRGB(r, g, b)
            addStroke(frame, col, 2.5, 0)
            halo1.BackgroundColor3 = col
            halo1.BackgroundTransparency = 0.35 + pulse * 0.25
            halo2.BackgroundColor3 = col
            halo2.BackgroundTransparency = 0.2 + pulse * 0.25
            lbl.TextColor3 = col
         end)
      else
         if pulseConn then pulseConn:Disconnect(); pulseConn = nil end
         addStroke(frame, Color3.fromRGB(110, 70, 40), 2.5, 0)
         halo1.BackgroundColor3 = Color3.fromRGB(140, 80, 40)
         halo1.BackgroundTransparency = 0.78
         halo2.BackgroundColor3 = Color3.fromRGB(180, 110, 50)
         halo2.BackgroundTransparency = 0.62
         rimBR.BackgroundColor3 = Color3.fromRGB(180, 110, 45)
         rimTL.BackgroundColor3 = Color3.fromRGB(200, 130, 60)
         lbl.TextColor3 = Color3.fromRGB(50, 35, 25)
      end
   end

   local btn = Instance.new("TextButton", frame)
   btn.Size = UDim2.new(1, 0, 1, 0)
   btn.Position = UDim2.new(0, 0, 0, 0)
   btn.BackgroundTransparency = 1
   btn.Text = ""; btn.ZIndex = 107

   btn.MouseButton1Down:Connect(function()
