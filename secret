-- ====================== TOGGLE FUNCTIONS ======================
local tweeninfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function setAntiBatState(active)
	if active then
		Ts:Create(cardstroke, tweeninfo, {Color = Color3.fromRGB(0, 255, 0)}):Play()
		status.Text = "ENABLED"
		Ts:Create(status, tweeninfo, {TextColor3 = Color3.fromRGB(0, 255, 0)}):Play()
		Ts:Create(pillbg, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 30, 0)}):Play()
		Ts:Create(knob, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 255, 0)}):Play()
		Ts:Create(knob, tweeninfo, {Position = UDim2.new(0, 22, 0.5, -7)}):Play()
	else
		Ts:Create(cardstroke, tweeninfo, {Color = Color3.fromRGB(0, 80, 0)}):Play()
		status.Text = "DISABLED"
		Ts:Create(status, tweeninfo, {TextColor3 = Color3.fromRGB(0, 150, 0)}):Play()
		Ts:Create(pillbg, tweeninfo, {BackgroundColor3 = Color3.fromRGB(0, 40, 0)}):Play()
		Ts:Create(knob, tweeninfo, {BackgroundColor3 = Color3.fromRGB(80, 85, 95)}):Play()
		Ts:Create(knob, tweeninfo, {Position = UDim2.new(0, 4, 0.5, -7)}):Play()
	end
end

