        if text == "Anti Ragdoll" then
            AntiRagdoll.Enabled = enabled
            if enabled then startAntiRagdoll() else stopAntiRagdoll() end
        end

        if text == "Auto Steal Nearest" then
            AutoSteal.Enabled = enabled
            if enabled then
                AutoSteal.heartbeatConn = RunService.Heartbeat:Connect(function()
                    if not AutoSteal.Enabled or AutoSteal.isStealing then return end
                    local prompt = findNearestPrompt()
                    if prompt then executeSteal(prompt) end
                end)
