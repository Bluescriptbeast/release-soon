        Instance.new("UICorner", dot).CornerRadius = UDim.new(0,4)
        local isOn = defOn or false
        local function setV(on)
            isOn = on
            TweenService:Create(pbg, TweenInfo.new(0.18), {BackgroundColor3 = on and Color3.fromRGB(160,0,0) or Color3.fromRGB(20,0,0)}):Play()
            TweenService:Create(ps, TweenInfo.new(0.18), {Color = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(160,0,0), Transparency = on and 0 or 1}):Play()
            TweenService:Create(dot, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
                Position = on and UDim2.new(1,-14,0.5,-6) or UDim2.new(0,2,0.5,-6),
                BackgroundColor3 = Color3.fromRGB(255,255,255)
            }):Play()
        end
        local clk = Instance.new("TextButton", parent)
        clk.Size = UDim2.new(1,0,1,0)
        clk.BackgroundTransparency = 1
        clk.Text = ""
        clk.ZIndex = 6
        clk.MouseButton1Click:Connect(function()
