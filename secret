local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local antibatActive = false
local antibatConnection = nil

-- ==================== ANTI BAT ====================
local function startAntiBat()
	if antibatConnection then
		antibatConnection:Disconnect()
		antibatConnection = nil
	end

	local character = LocalPlayer.Character
	if not character then return end
	
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	antibatConnection = RunService.Heartbeat:Connect(function()
		if not rootPart or not rootPart.Parent then return end
		
		local originalVelocity = rootPart.AssemblyLinearVelocity
		rootPart.AssemblyLinearVelocity = Vector3.new(1000, originalVelocity.Y, 1000)
		
		task.spawn(function()
			RunService.RenderStepped:Wait()
			if rootPart and rootPart.Parent then
				rootPart.AssemblyLinearVelocity = originalVelocity
			end
		end)
	end)
end

local function stopAntiBat()
	if antibatConnection then
		antibatConnection:Disconnect()
		antibatConnection = nil
	end
end

-- ==================== INFINITY JUMP ====================
local INF_JUMP_FORCE = 54
local CLAMP_FALL = 80

local infJumpEnabled = false
local jumpConnection = nil
local fallConnection = nil

local function getHRP()
	local char = LocalPlayer.Character
	if char then
		return char:FindFirstChild("HumanoidRootPart")
	end
	return nil
end

local function applyInfJump()
	if jumpConnection then jumpConnection:Disconnect() end
	if fallConnection then fallConnection:Disconnect() end

	jumpConnection = UserInputService.JumpRequest:Connect(function()
		if not infJumpEnabled then return end
		local hrp = getHRP()
		if not hrp then return end
		
		hrp.AssemblyLinearVelocity = Vector3.new(
			hrp.AssemblyLinearVelocity.X,
			INF_JUMP_FORCE,
			hrp.AssemblyLinearVelocity.Z
		)
	end)

	fallConnection = RunService.Heartbeat:Connect(function()
		if not infJumpEnabled then return end
		local hrp = getHRP()
		if not hrp then return end
		
		local vel = hrp.AssemblyLinearVelocity
		if vel.Y < -CLAMP_FALL then
			hrp.AssemblyLinearVelocity = Vector3.new(vel.X, -CLAMP_FALL, vel.Z)
		end
	end)
end

local function toggleInfJump(state)
	infJumpEnabled = state
	if state then
		applyInfJump()
	else
		if jumpConnection then jumpConnection:Disconnect() end
		if fallConnection then fallConnection:Disconnect() end
	end
end

