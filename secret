    bot.TextScaled = true
    bot.TextXAlignment = Enum.TextXAlignment.Center
    bot.TextYAlignment = Enum.TextYAlignment.Top
    bot.ZIndex = 31

    local function toggle()
        Config[bd.fk] = not Config[bd.fk]
        local active = Config[bd.fk]
        
        TweenService:Create(wrap, TweenInfo.new(0.22), {
            BackgroundColor3 = active and Color3.fromRGB(0, 170, 80) or Color3.fromRGB(8, 0, 0)
        }):Play()
        stroke.Color = active and Color3.fromRGB(0, 255, 140) or Color3.fromRGB(0, 100, 60)

        if bd.fk == "autoLeft" then
            if active then startAutoLeft() end
        elseif bd.fk == "autoRight" then
            if active then startAutoRight() end
        elseif bd.fk == "carrySpeed" then
            -- carry speed toggle
        end
    end

    wrap.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            toggle()
        end
    end)
