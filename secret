-- ==================== UTILITY ====================
local function createCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
end

local function createStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or CONFIG.Accent.StrokeColor
    s.Thickness = thickness or 1.6
    s.Parent = parent
    return s
end

local function createGradient(parent)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 25, 10)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(80, 255, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 25, 10)),
    }
    g.Parent = parent
    return g
end

local function makeDraggable(frame)
    local dragging = false
    local dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            dragInput = input
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- ==================== PROGRESS BAR ====================
local currentTween = nil
local function animateProgressBar(duration)
    if not ProgressFill then return end
    if currentTween then currentTween:Cancel() end

    ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local goal = {Size = UDim2.new(1, 0, 1, 0)}
    currentTween = TweenService:Create(ProgressFill, tweenInfo, goal)
    currentTween:Play()

    currentTween.Completed:Connect(function()
        task.wait(0.1)
        if ProgressFill then ProgressFill.Size = UDim2.new(0, 0, 1, 0) end
    end)
end

-- ==================== SPEED BOOST ====================
local function setupSpeedBoost()
    if speedConnection then speedConnection:Disconnect() end

    speedConnection = RunService.Heartbeat:Connect(function()
        if not speedBoostEnabled then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if hum and root then
            hum.WalkSpeed = speedBoostValue
        end
    end)
end

-- ==================== AUTO POTION ====================
local function setupAutoPotion()
    -- Basit auto potion (kendi oyununuzdaki potion logic'ine göre düzenleyebilirsiniz)
    task.spawn(function()
        while task.wait(1) do
            if not autoPotionEnabled then continue end
            local char = LocalPlayer.Character
            if char then
                for _, tool in ipairs(char:GetChildren()) do
                    if tool:IsA("Tool") and (tool.Name:lower():find("potion") or tool.Name:lower():find("heal")) then
                        tool:Activate()
                        break
                    end
                end
            end
        end
    end)
end

-- ==================== AP SPAMMER ====================
local function setupAPSpammer()
    task.spawn(function()
        while task.wait(0.15) do
            if not apSpammerEnabled then continue end
            local char = LocalPlayer.Character
            local tool = char and char:FindFirstChildOfClass("Tool")
            if tool then
                tool:Activate()
            end
        end
    end)
end

-- ==================== TOGGLE ====================
local function createSimpleToggle(parent, yPos, text, default, callback)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, -20, 0, 32)
    toggleFrame.Position = UDim2.new(0, 10, 0, yPos)
    toggleFrame.BackgroundColor3 = Color3.fromRGB(20, 35, 25)
    toggleFrame.Parent = parent
    createCorner(toggleFrame, 6)
    createStroke(toggleFrame, CONFIG.Accent.StrokeColor, 1.2)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(180, 255, 200)
    label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame

    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0, 40, 1, 0)
    status.Position = UDim2.new(1, -12, 0, 0)
    status.AnchorPoint = Vector2.new(1, 0)
    status.BackgroundTransparency = 1
    status.Text = default and "ON" or "OFF"
    status.TextColor3 = default and Color3.fromRGB(120, 255, 140) or Color3.fromRGB(255, 90, 90)
    status.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
    status.TextSize = 13
    status.TextXAlignment = Enum.TextXAlignment.Right
    status.Parent = toggleFrame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.BackgroundTransparency = 1
    button.Text = ""
    button.Parent = toggleFrame

    local enabled = default
    button.MouseButton1Click:Connect(function()
        enabled = not enabled
        status.Text = enabled and "ON" or "OFF"
        status.TextColor3 = enabled and Color3.fromRGB(120, 255, 140) or Color3.fromRGB(255, 90, 90)
        callback(enabled)
    end)
end

