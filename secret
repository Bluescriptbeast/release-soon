local function loadConfig()
    if isfile and isfile(configFile) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(configFile))
        end)
        if success and data then
            for k, v in pairs(data) do
                if config[k] ~= nil then
                    config[k] = v
                end
            end
        end
    else
        pcall(function()
            writefile(configFile, HttpService:JSONEncode(config))
        end)
    end
end

local function saveConfig()
    config.flashTPEnabled = flashTPEnabled
    config.giantPotionEnabled = giantPotionEnabled
    config.apSpammerEnabled = apSpammerEnabled
    config.zeroGravityEnabled = zeroGravityEnabled
    config.kickAfterStealEnabled = kickAfterStealEnabled
    config.triggerValue = triggerValue

    pcall(function()
        writefile(configFile, HttpService:JSONEncode(config))
    end)
end

